# Downloaded, self-contained kitty binary bundle (fetched by bootstrap.sh).
# Not part of the source; each machine pulls its own via ./bootstrap.sh.
/kitty.app/
/kitty.app.old/

# Runtime state
/.last-update-check
/.kilix-fork-built-ref

# Python bytecode, anywhere
__pycache__/

# Compiled screensaver binaries (built on first use from config/screensavers/*.c)
config/screensavers/.build/

# kilix 95 desktop: user-supplied fonts (never committed — see
# desktop/README.md; period fonts stay local for copyright reasons)
desktop/assets/
