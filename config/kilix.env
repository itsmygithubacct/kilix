# kilix runtime settings
#
# This file stores Kilix-specific settings that are not kitty.conf options.
# The kilix launcher reads simple KEY=value lines from this file and exports
# only known KILIX_* keys. Lines are intentionally not shell-evaluated.
#
# Examples:
# KILIX_CHROME_CLOCK=0
# KILIX_CHROME_BATTERY=1
# KILIX_CHROME_CLOCK_FORMAT=%Y-%m-%d %H:%M
# KILIX_DESKTOP_PROVIDER=auto
# KILIX_RUN_AUTO_FIT=1
# KILIX_HW=1
# KILIX_SHELL_INTEGRATION=0
