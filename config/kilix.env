# kilix runtime settings
#
# This tracked file documents immutable defaults for Kilix-specific settings.
# Put user overrides in ~/.local/gpu_terminal/kilix/config/kilix.env. The
# launcher reads simple KEY=value lines and exports only known KILIX_* keys;
# lines are intentionally not shell-evaluated.
# Storage roots are process/service settings, not persisted here: use
# KILIX_STORAGE_HOME and KILIX95_STORAGE_HOME in the launching environment.
#
# Clickable chrome is shared by all projects in
# ~/.local/gpu_terminal/settings.conf and is managed by `kilix-settings`.
# Legacy KILIX_CHROME_CLOCK/BATTERY values here are migrated when that shared
# file is first created, but new chrome preferences belong in settings.conf.
#
# Runtime examples:
# KILIX_DESKTOP_PROVIDER=auto
# KILIX_DESKTOP_FLAVOR=xp
# KILIX_RUN_AUTO_FIT=1
# KILIX_BROWSE_BACKEND=presenter
# KILIX_HW=1
# KILIX_SHELL_INTEGRATION=0
# KILIX95_REF=<full-40-character-commit-sha>
# KILIX95_DIR=~/gpu_terminal/kilix-95
# KILIX95_ALLOW_MUTABLE_REF=0
# KILIX95_ALLOW_UNPINNED_INSTALL=0
# KILIX_REPO=https://github.com/itsmygithubacct/kilix.git
# KILIX_TRUST_EXISTING_CHECKOUT=0
# KILIX_ALLOW_MUTABLE_REF=0
# KILIX_PREBUILT_VERSION=0.47.0
# KILIX_PREBUILT_SHA256=<sha256>
# KILIX_ALLOW_UNVERIFIED_PREBUILT=0
# KILIX_BUILD_MODE=system
# KILIX_KITTY_DEPS_URL=<immutable-versioned-asset-url>
# KILIX_KITTY_DEPS_SHA256=<sha256>
# KILIX_NERD_FONT_URL=<versioned-asset-url>
# KILIX_NERD_FONT_SHA256=<sha256>
# KILIX_NERD_FONT_FILE_SHA256=<sha256>

# Pinned Tmux Manager download-on-first-run closure. The launcher supplies
# immutable defaults; uncomment only to point at another reviewed closure.
# TMUX_TUI_REPO=https://github.com/itsmygithubacct/tmux-tui.git
# TMUX_TUI_REF=<full-40-character-commit-sha>
# TMUX_CLI_REF=<full-40-character-commit-sha>
# Prefix overrides must be normalized absolute paths.
# TMUX_TUI_PREFIX=$HOME/.local
# KILIX_GO_TOOLCHAIN=go1.26.5
# KILIX_PYTHON=/path/to/python3.12
