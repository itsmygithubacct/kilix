#!/usr/bin/env python3
"""Terminal UI and CLI for shared Kilix controls and game availability."""

from __future__ import annotations

import argparse
import curses
import os
from pathlib import Path
import signal
import sys


sys.dont_write_bytecode = True
ROOT = Path(__file__).resolve().parent
sys.path.insert(0, str(ROOT / "config"))

from kilix_sdk import settings as shared  # noqa: E402


def _control_names() -> dict[str, str]:
    names: dict[str, str] = {}
    for spec in shared.TOGGLE_SPECS:
        if spec.key.startswith("KILIX_GAME_"):
            short = spec.key.removeprefix("KILIX_GAME_").lower()
            names[short] = spec.key
            names[f"game_{short}"] = spec.key
        else:
            short = spec.key.removeprefix("KILIX_CHROME_").lower()
            names[short] = spec.key
            names[short.removeprefix("button_")] = spec.key
        names[spec.key.lower()] = spec.key
    for game_id, key in shared.GAME_KEY_BY_ID.items():
        names[game_id] = key
        names[game_id.replace("-", "_")] = key
    return names


CONTROL_NAMES = _control_names()
GAME_NAMES = {
    alias: key for alias, key in CONTROL_NAMES.items()
    if key in shared.GAME_ID_BY_KEY
}


def _parse_assignment(value: str) -> tuple[str, bool]:
    try:
        name, raw = value.split("=", 1)
    except ValueError as error:
        raise argparse.ArgumentTypeError("expected CONTROL=on|off") from error
    key = CONTROL_NAMES.get(name.strip().lower())
    if key is None:
        choices = ", ".join(sorted(
            key for key in CONTROL_NAMES if not key.startswith("kilix_")))
        raise argparse.ArgumentTypeError(
            f"unknown control {name!r}; choose one of: {choices}")
    return key, shared.truthy(raw)


def _parse_game_assignment(value: str) -> tuple[str, bool]:
    try:
        name, raw = value.split("=", 1)
    except ValueError as error:
        raise argparse.ArgumentTypeError("expected GAME=on|off") from error
    key = GAME_NAMES.get(name.strip().lower())
    if key is None:
        choices = ", ".join(game_id for game_id, _ in shared.GAME_TOGGLE_IDS)
        raise argparse.ArgumentTypeError(
            f"unknown game {name!r}; choose one of: {choices}")
    return key, shared.truthy(raw)


def _notify_running_kilix() -> None:
    raw_pid = os.environ.get("KITTY_PID", "")
    if raw_pid.isdigit():
        try:
            os.kill(int(raw_pid), signal.SIGUSR1)
        except OSError:
            pass


def _print_settings(values: dict[str, str]) -> None:
    print(f"settings_file={shared.settings_path()}")
    for spec in shared.TOGGLE_SPECS:
        state = "on" if shared.truthy(values[spec.key]) else "off"
        print(f"{spec.key}={state}")
    print(f"{shared.CLOCK_FORMAT_KEY}={values[shared.CLOCK_FORMAT_KEY]}")


def _print_games(values: dict[str, str]) -> None:
    print(f"settings_file={shared.settings_path()}")
    for game_id, label in shared.GAME_TOGGLE_IDS:
        key = shared.GAME_KEY_BY_ID[game_id]
        state = "on" if shared.truthy(values[key]) else "off"
        print(f"{game_id}={state}\t{label}")


def _content_rows(values: dict[str, bool]):
    rows = []
    current_section = ""
    item_index = 0
    for spec in shared.TOGGLE_SPECS:
        if spec.section != current_section:
            current_section = spec.section
            if rows:
                rows.append(("blank", "", None))
            rows.append(("section", current_section, None))
        marker = "[x]" if values[spec.key] else "[ ]"
        rows.append(("item", f" {marker} {spec.label}", item_index))
        item_index += 1
    return rows


def _draw(stdscr, values: dict[str, bool], selected: int,
          message: str = "") -> None:
    stdscr.erase()
    height, width = stdscr.getmaxyx()
    title = "Kilix Settings"
    path = shared.settings_path()
    try:
        stdscr.addnstr(0, 2, title, max(0, width - 4), curses.A_BOLD)
        stdscr.addnstr(1, 2, path, max(0, width - 4), curses.A_DIM)
    except curses.error:
        pass

    content = _content_rows(values)
    selected_row = next(
        (i for i, (_kind, _line, index) in enumerate(content)
         if index == selected), 0)
    available = max(1, height - 6)
    scroll = min(max(0, selected_row - available + 1),
                 max(0, len(content) - available))
    for row_offset, (kind, line, item_index) in enumerate(
            content[scroll:scroll + available]):
        row = 3 + row_offset
        attr = curses.A_NORMAL
        if kind == "section":
            attr = curses.A_BOLD
        elif kind == "item" and item_index == selected:
            attr = curses.A_REVERSE
        try:
            stdscr.addnstr(row, 2, line, max(0, width - 4), attr)
        except curses.error:
            pass

    more = ""
    if scroll:
        more += "↑ "
    if scroll + available < len(content):
        more += "↓ "
    help_text = (more +
                 "j/k move · Space toggle · A all on · N all off · S save · Q quit")
    if height > 2:
        try:
            stdscr.addnstr(height - 2, 1, message or help_text,
                           max(0, width - 2), curses.A_BOLD if message else curses.A_DIM)
        except curses.error:
            pass
    stdscr.refresh()


def _run_tui(stdscr) -> int:
    try:
        curses.curs_set(0)
    except curses.error:
        pass
    stdscr.keypad(True)
    effective = shared.load()
    values = {
        spec.key: shared.truthy(effective[spec.key])
        for spec in shared.TOGGLE_SPECS
    }
    original = dict(values)
    selected = 0
    message = ""
    count = len(shared.TOGGLE_SPECS)

    while True:
        _draw(stdscr, values, selected, message)
        message = ""
        key = stdscr.getch()
        if key in (curses.KEY_UP, ord("k"), ord("K")):
            selected = (selected - 1) % count
        elif key in (curses.KEY_DOWN, ord("j"), ord("J")):
            selected = (selected + 1) % count
        elif key in (ord(" "), curses.KEY_ENTER, 10, 13):
            name = shared.TOGGLE_SPECS[selected].key
            values[name] = not values[name]
        elif key in (ord("a"), ord("A")):
            values = {name: True for name in values}
        elif key in (ord("n"), ord("N")):
            values = {name: False for name in values}
        elif key in (ord("s"), ord("S")):
            changes = {
                name: state for name, state in values.items()
                if original[name] != state
            }
            if changes:
                try:
                    shared.update(changes)
                except OSError as error:
                    message = f"Could not save: {error}"
                else:
                    original = dict(values)
                    _notify_running_kilix()
                    message = "Saved. New game menus and Kilix chrome use these settings."
            else:
                message = "No changes to save."
        elif key in (ord("q"), ord("Q"), 27):
            if values != original:
                message = "Unsaved changes: press S to save, or Q again to discard."
                _draw(stdscr, values, selected, message)
                if stdscr.getch() not in (ord("q"), ord("Q"), 27):
                    continue
            return 0
        elif key == curses.KEY_RESIZE:
            continue


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description="Configure Kilix chrome and game availability")
    parser.add_argument("--print", action="store_true", dest="show",
                        help="print the effective shared settings")
    parser.add_argument("--print-games", action="store_true",
                        help="print Kilix game availability")
    parser.add_argument("--ensure", action="store_true",
                        help="create the shared settings file if absent")
    parser.add_argument("--set", action="append", default=[],
                        type=_parse_assignment, metavar="CONTROL=on|off",
                        help="set a control non-interactively")
    parser.add_argument("--game", action="append", default=[],
                        type=_parse_game_assignment, metavar="GAME=on|off",
                        help="set game availability non-interactively")
    all_group = parser.add_mutually_exclusive_group()
    all_group.add_argument("--enable-all", action="store_true",
                           help="enable every shared control and game")
    all_group.add_argument("--disable-all", action="store_true",
                           help="disable every shared control and game")
    args = parser.parse_args(argv)

    try:
        shared.ensure_file()
        changes: dict[str, bool] = {}
        if args.enable_all or args.disable_all:
            state = bool(args.enable_all)
            changes.update((spec.key, state) for spec in shared.TOGGLE_SPECS)
        changes.update(args.set)
        changes.update(args.game)
        if changes:
            shared.update(changes)
            _notify_running_kilix()
        if args.show:
            _print_settings(shared.load())
        if args.print_games:
            _print_games(shared.load())
    except (OSError, KeyError) as error:
        parser.exit(1, f"kilix-settings: {error}\n")

    if args.ensure or args.show or args.print_games or changes:
        return 0
    if not sys.stdin.isatty() or not sys.stdout.isatty():
        parser.error(
            "the interactive TUI requires a terminal; use --print, "
            "--print-games, --set, or --game")
    return curses.wrapper(_run_tui)


if __name__ == "__main__":
    raise SystemExit(main())
