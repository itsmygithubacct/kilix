#!/usr/bin/env python3
"""Terminal UI and CLI for shared Kilix controls and game availability."""

from __future__ import annotations

import argparse
import curses
import os
from pathlib import Path
import signal
import sys
from typing import NamedTuple


sys.dont_write_bytecode = True
ROOT = Path(__file__).resolve().parent
sys.path.insert(0, str(ROOT / "config"))

from kilix_sdk import settings as shared  # noqa: E402


def _control_names() -> dict[str, str]:
    names: dict[str, str] = {}
    for spec in shared.TOGGLE_SPECS:
        if spec.key.startswith("KILIX_GAME_"):
            short = spec.key.removeprefix("KILIX_GAME_").lower()
            names[short] = spec.key
            names[f"game_{short}"] = spec.key
        else:
            short = spec.key.removeprefix("KILIX_CHROME_").lower()
            names[short] = spec.key
            names[short.removeprefix("button_")] = spec.key
        names[spec.key.lower()] = spec.key
    for game_id, key in shared.GAME_KEY_BY_ID.items():
        names[game_id] = key
        names[game_id.replace("-", "_")] = key
    for alias in (
        "memory",
        "memory_chip",
        "memory_mode",
        "pane_memory",
        "pane_memory_mode",
    ):
        names[alias] = shared.PANE_MEMORY_MODE_KEY
    names[shared.PANE_MEMORY_MODE_KEY.lower()] = shared.PANE_MEMORY_MODE_KEY
    return names


CONTROL_NAMES = _control_names()
GAME_NAMES = {
    alias: key for alias, key in CONTROL_NAMES.items()
    if key in shared.GAME_ID_BY_KEY
}


class ChoiceSpec(NamedTuple):
    key: str
    label: str
    choices: tuple[str, ...]
    default: str


MEMORY_MODE_SPEC = ChoiceSpec(
    shared.PANE_MEMORY_MODE_KEY,
    "Pane memory chip (auto ≥1 GiB / always / off)",
    shared.PANE_MEMORY_MODE_CHOICES,
    shared.PANE_MEMORY_MODE_DEFAULT,
)


SECTION_SPECS = tuple(
    (
        section,
        ((MEMORY_MODE_SPEC,) if section == "Pane buttons" else ())
        + tuple(
            spec for spec in shared.TOGGLE_SPECS
            if spec.section == section
        ),
    )
    for section in dict.fromkeys(spec.section for spec in shared.TOGGLE_SPECS)
)


class ToolSpec(NamedTuple):
    key: str
    label: str


TOOL_SPECS = (
    ToolSpec("memory-monitor", "Kilix Memory — monitor RAM"),
    ToolSpec("tmux-manager", "Tmux Manager — download and run"),
    ToolSpec("install-tb", "Install / repair tmux-cli's tb command"),
)
UI_SECTIONS = SECTION_SPECS + (("Tools", TOOL_SPECS),)
TOOLS_SECTION_INDEX = len(SECTION_SPECS)
SECTION_ALIASES = {
    "top": 0,
    "top-bar": 0,
    "top_bar": 0,
    "pane": 1,
    "panes": 1,
    "pane-buttons": 1,
    "pane_buttons": 1,
    "game": 2,
    "games": 2,
    "tool": TOOLS_SECTION_INDEX,
    "tools": TOOLS_SECTION_INDEX,
}


def _parse_assignment(value: str) -> tuple[str, object]:
    try:
        name, raw = value.split("=", 1)
    except ValueError as error:
        raise argparse.ArgumentTypeError(
            "expected CONTROL=on|off or pane_memory=auto|always|off"
        ) from error
    key = CONTROL_NAMES.get(name.strip().lower())
    if key is None:
        choices = ", ".join(sorted(
            key for key in CONTROL_NAMES if not key.startswith("kilix_")))
        raise argparse.ArgumentTypeError(
            f"unknown control {name!r}; choose one of: {choices}")
    if key == shared.PANE_MEMORY_MODE_KEY:
        mode = raw.strip().lower()
        if mode == "on":
            mode = "always"
        if mode not in shared.PANE_MEMORY_MODE_CHOICES:
            choices = "|".join(shared.PANE_MEMORY_MODE_CHOICES)
            raise argparse.ArgumentTypeError(
                f"pane memory mode must be {choices}"
            )
        return key, mode
    return key, shared.truthy(raw)


def _parse_game_assignment(value: str) -> tuple[str, bool]:
    try:
        name, raw = value.split("=", 1)
    except ValueError as error:
        raise argparse.ArgumentTypeError("expected GAME=on|off") from error
    key = GAME_NAMES.get(name.strip().lower())
    if key is None:
        choices = ", ".join(game_id for game_id, _ in shared.GAME_TOGGLE_IDS)
        raise argparse.ArgumentTypeError(
            f"unknown game {name!r}; choose one of: {choices}")
    return key, shared.truthy(raw)


def _parse_section(value: str) -> int:
    section = SECTION_ALIASES.get(value.strip().lower())
    if section is None:
        raise argparse.ArgumentTypeError(
            "unknown section; choose top-bar, pane-buttons, games, or tools")
    return section


def _notify_running_kilix() -> None:
    raw_pid = os.environ.get("KITTY_PID", "")
    if raw_pid.isdigit():
        try:
            os.kill(int(raw_pid), signal.SIGUSR1)
        except OSError:
            pass


def _print_settings(values: dict[str, str]) -> None:
    print(f"settings_file={shared.settings_path()}")
    for spec in shared.TOGGLE_SPECS:
        state = "on" if shared.truthy(values[spec.key]) else "off"
        print(f"{spec.key}={state}")
    mode = values.get(
        shared.PANE_MEMORY_MODE_KEY, shared.PANE_MEMORY_MODE_DEFAULT
    ).strip().lower()
    if mode not in shared.PANE_MEMORY_MODE_CHOICES:
        mode = shared.PANE_MEMORY_MODE_DEFAULT
    print(f"{shared.PANE_MEMORY_MODE_KEY}={mode}")
    print(f"{shared.CLOCK_FORMAT_KEY}={values[shared.CLOCK_FORMAT_KEY]}")


def _print_games(values: dict[str, str]) -> None:
    print(f"settings_file={shared.settings_path()}")
    for game_id, label in shared.GAME_TOGGLE_IDS:
        key = shared.GAME_KEY_BY_ID[game_id]
        state = "on" if shared.truthy(values[key]) else "off"
        print(f"{game_id}={state}\t{label}")


def _draw_tabs(stdscr, width: int, active: int) -> None:
    column = 2
    for index, (section, _specs) in enumerate(UI_SECTIONS):
        label = f" {index + 1} {section} "
        if column >= width - 1:
            break
        attr = (curses.A_REVERSE | curses.A_BOLD
                if index == active else curses.A_DIM)
        try:
            stdscr.addnstr(3, column, label, max(0, width - column - 1), attr)
        except curses.error:
            pass
        column += len(label) + 1


def _draw(stdscr, values: dict[str, object], original: dict[str, object],
          section_index: int, selected: int, message: str = "") -> None:
    stdscr.erase()
    height, width = stdscr.getmaxyx()
    dirty = sum(values[key] != original[key] for key in values)
    title = "Kilix Settings" + (f" — {dirty} unsaved" if dirty else "")
    path = shared.settings_path()
    try:
        stdscr.addnstr(0, 2, title, max(0, width - 4), curses.A_BOLD)
        stdscr.addnstr(1, 2, path, max(0, width - 4), curses.A_DIM)
    except curses.error:
        pass

    _draw_tabs(stdscr, width, section_index)
    section, specs = UI_SECTIONS[section_index]
    tools = section_index == TOOLS_SECTION_INDEX
    try:
        if tools:
            summary = "Tools: Enter runs the selected tool"
        else:
            enabled_count = sum(
                str(values[spec.key]) != "off"
                if isinstance(spec, ChoiceSpec)
                else bool(values[spec.key])
                for spec in specs
            )
            summary = f"{section}: {enabled_count}/{len(specs)} enabled"
        stdscr.addnstr(
            4, 2, summary,
            max(0, width - 4), curses.A_BOLD)
    except curses.error:
        pass

    available = max(1, height - 8)
    scroll = min(max(0, selected - available + 1),
                 max(0, len(specs) - available))
    for row_offset, spec in enumerate(specs[scroll:scroll + available]):
        item_index = scroll + row_offset
        row = 5 + row_offset
        if tools:
            marker = "[>]"
        elif isinstance(spec, ChoiceSpec):
            marker = f"[{str(values[spec.key]):^6}]"
        else:
            marker = "[x]" if values[spec.key] else "[ ]"
        line = f" {marker} {spec.label}"
        attr = curses.A_REVERSE if item_index == selected else curses.A_NORMAL
        try:
            stdscr.addnstr(row, 2, line, max(0, width - 4), attr)
        except curses.error:
            pass

    more = []
    if scroll:
        more.append("↑ more")
    if scroll + available < len(specs):
        more.append("↓ more")
    if height >= 10:
        status = " · ".join(more) or "All changes saved"
        if dirty:
            status = (" · ".join(more) + (" · " if more else "")
                      + f"{dirty} unsaved change{'s' if dirty != 1 else ''}")
        try:
            stdscr.addnstr(height - 3, 2, status, max(0, width - 4),
                           curses.A_BOLD if dirty else curses.A_DIM)
        except curses.error:
            pass

    help_text = (
        "←/→ section · ↑/↓ move · Enter select · q quit"
        if tools else
        "←/→ section · ↑/↓ move · Space toggle · "
        "a/n section · A/N all · s save · q quit"
    )
    if height > 2:
        try:
            stdscr.addnstr(height - 2, 1, message or help_text,
                           max(0, width - 2),
                           curses.A_BOLD if message else curses.A_DIM)
        except curses.error:
            pass
    stdscr.refresh()


def _run_tui(stdscr, initial_section: int | str | None = None) -> int | str:
    try:
        curses.curs_set(0)
    except curses.error:
        pass
    stdscr.keypad(True)
    effective = shared.load()
    values = {
        spec.key: shared.truthy(effective[spec.key])
        for spec in shared.TOGGLE_SPECS
    }
    values[shared.PANE_MEMORY_MODE_KEY] = shared.pane_memory_mode()
    original = dict(values)
    if isinstance(initial_section, str):
        section_index = _parse_section(initial_section)
    else:
        section_index = initial_section or 0
    selected = [0] * len(UI_SECTIONS)
    message = ""
    discard_armed = False

    while True:
        specs = UI_SECTIONS[section_index][1]
        tools = section_index == TOOLS_SECTION_INDEX
        item_index = selected[section_index]
        _draw(stdscr, values, original, section_index, item_index, message)
        message = ""
        key = stdscr.getch()
        if key not in (ord("q"), ord("Q"), 27):
            discard_armed = False
        if key in (curses.KEY_UP, ord("k"), ord("K")):
            selected[section_index] = (item_index - 1) % len(specs)
        elif key in (curses.KEY_DOWN, ord("j"), ord("J")):
            selected[section_index] = (item_index + 1) % len(specs)
        elif key in (curses.KEY_LEFT, ord("h"), ord("H"),
                     getattr(curses, "KEY_BTAB", -1)):
            section_index = (section_index - 1) % len(UI_SECTIONS)
        elif key in (curses.KEY_RIGHT, ord("l"), ord("L"), ord("\t")):
            section_index = (section_index + 1) % len(UI_SECTIONS)
        elif ord("1") <= key <= ord(str(len(UI_SECTIONS))):
            section_index = key - ord("1")
        elif key == curses.KEY_HOME:
            selected[section_index] = 0
        elif key == curses.KEY_END:
            selected[section_index] = len(specs) - 1
        elif key == curses.KEY_PPAGE:
            selected[section_index] = max(0, item_index - 5)
        elif key == curses.KEY_NPAGE:
            selected[section_index] = min(len(specs) - 1, item_index + 5)
        elif key in (ord(" "), curses.KEY_ENTER, 10, 13):
            if tools:
                if values != original:
                    message = "Save or discard changes before launching a tool."
                else:
                    return f"tool:{specs[item_index].key}"
            else:
                spec = specs[item_index]
                name = spec.key
                if isinstance(spec, ChoiceSpec):
                    current = str(values[name])
                    try:
                        index = spec.choices.index(current)
                    except ValueError:
                        index = -1
                    values[name] = spec.choices[
                        (index + 1) % len(spec.choices)]
                else:
                    values[name] = not values[name]
        elif key == ord("a"):
            if tools:
                message = "Tools are actions; press Enter to select one."
            else:
                for spec in specs:
                    values[spec.key] = (
                        spec.default if isinstance(spec, ChoiceSpec) else True)
        elif key == ord("n"):
            if tools:
                message = "Tools are actions; press Enter to select one."
            else:
                for spec in specs:
                    values[spec.key] = (
                        "off" if isinstance(spec, ChoiceSpec) else False)
        elif key == ord("A"):
            if tools:
                message = "Tools are actions; press Enter to select one."
            else:
                for name in values:
                    values[name] = (
                        shared.PANE_MEMORY_MODE_DEFAULT
                        if name == shared.PANE_MEMORY_MODE_KEY else True)
        elif key == ord("N"):
            if tools:
                message = "Tools are actions; press Enter to select one."
            else:
                for name in values:
                    values[name] = (
                        "off"
                        if name == shared.PANE_MEMORY_MODE_KEY else False)
        elif key in (ord("s"), ord("S")):
            changes = {
                name: state for name, state in values.items()
                if original[name] != state
            }
            if changes:
                try:
                    shared.update(changes)
                except OSError as error:
                    message = f"Could not save: {error}"
                else:
                    original = dict(values)
                    _notify_running_kilix()
                    message = (
                        "Saved. Chrome refreshes live; game menus update "
                        "when reopened.")
            else:
                message = "No changes to save."
        elif key in (ord("q"), ord("Q"), 27):
            if values != original and not discard_armed:
                message = "Unsaved changes: s saves; q again discards."
                discard_armed = True
                continue
            return 0
        elif key == curses.KEY_RESIZE:
            continue


def _tool_argv(action: str) -> list[str]:
    kilix = str(ROOT / "kilix")
    if action == "memory-monitor":
        return [kilix, "memory", "--graphics"]
    if action == "tmux-manager":
        return [kilix, "tmux"]
    if action == "install-tb":
        return [kilix, "tmux", "--install-only", "--with-tb"]
    raise ValueError(f"unknown tool action: {action}")


def _exec_tool(action: str) -> None:
    argv = _tool_argv(action)
    os.execv(argv[0], argv)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description="Configure Kilix chrome and game availability")
    parser.add_argument("--print", action="store_true", dest="show",
                        help="print the effective shared settings")
    parser.add_argument("--print-games", action="store_true",
                        help="print Kilix game availability")
    parser.add_argument("--ensure", action="store_true",
                        help="create the shared settings file if absent")
    parser.add_argument("--set", action="append", default=[],
                        type=_parse_assignment,
                        metavar="CONTROL=VALUE",
                        help=("set a toggle to on/off or pane_memory to "
                              "auto/always/off"))
    parser.add_argument("--game", action="append", default=[],
                        type=_parse_game_assignment, metavar="GAME=on|off",
                        help="set game availability non-interactively")
    parser.add_argument("--section", type=_parse_section,
                        metavar="top-bar|pane-buttons|games|tools",
                        help="open the interactive TUI on this section")
    all_group = parser.add_mutually_exclusive_group()
    all_group.add_argument("--enable-all", action="store_true",
                           help="enable every shared control and game")
    all_group.add_argument("--disable-all", action="store_true",
                           help="disable every shared control and game")
    args = parser.parse_args(argv)

    try:
        shared.ensure_file()
        changes: dict[str, object] = {}
        if args.enable_all or args.disable_all:
            state = bool(args.enable_all)
            changes.update((spec.key, state) for spec in shared.TOGGLE_SPECS)
            changes[shared.PANE_MEMORY_MODE_KEY] = (
                shared.PANE_MEMORY_MODE_DEFAULT if state else "off")
        changes.update(args.set)
        changes.update(args.game)
        if changes:
            shared.update(changes)
            _notify_running_kilix()
        if args.show:
            _print_settings(shared.load())
        if args.print_games:
            _print_games(shared.load())
    except (OSError, KeyError, ValueError) as error:
        parser.exit(1, f"kilix-settings: {error}\n")

    if args.ensure or args.show or args.print_games or changes:
        return 0
    if not sys.stdin.isatty() or not sys.stdout.isatty():
        parser.error(
            "the interactive TUI requires a terminal; use --print, "
            "--print-games, --set, or --game")
    result = curses.wrapper(_run_tui, args.section)
    if isinstance(result, str) and result.startswith("tool:"):
        _exec_tool(result.removeprefix("tool:"))
        return 0
    return result


if __name__ == "__main__":
    raise SystemExit(main())
