#!/usr/bin/env bash
# kilix — a Tilix-styled kitty with clickable pane-title-bar buttons.
#
# Runs the forked kitty built from ./src (the "clickable-chrome" fork: each pane
# title bar gets clickable [|] [-] [maximize] [x] buttons) with the
# kilix configuration (Tilix-like per-pane title bars, splits, keybindings,
# theming). Falls back to a prebuilt kitty in ./kitty.app if the fork is not
# built yet. Fully self-contained; any extra args are forwarded to kitty.
#
#   ./kilix                   # launch kilix
#   ./kilix ls [--panes]      # list live kilix pages/tabs or panes in this instance
#   ./kilix focus <id>        # focus a live tab/pane by ID
#   ./kilix watch <pane-id>   # best-effort read-only text watch of a live pane
#   ./kilix mux [name]        # open a tmux-backed kilix tab for real attach/view
#   ./kilix screen-size ...   # show/increase/decrease/reset terminal scale
#   ./kilix status            # show version, engine, config, and provider
#   ./kilix update            # verified-origin, clean, fast-forward/ref update
#   ./kilix desktop           # launch the configured desktop provider
#   ./kilix --build           # build the forked kitty from ./src
#   ./kilix --which           # print the kitty binary kilix uses + its version
#   ./kilix --install-desktop # desktop entry + icon (own taskbar group)
set -euo pipefail

# Resolve symlinks so `ln -s .../kilix ~/.local/bin/kilix` still finds the project.
_self="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
KILIX_HOME="$(cd "$(dirname "$_self")" && pwd)"
FORK="$KILIX_HOME/src/kitty/launcher/kitty"     # built from ./src (clickable chrome)
PREBUILT="$KILIX_HOME/kitty.app/bin/kitty"      # official prebuilt kitty (fallback)

# Tracked files under ./config are immutable defaults.  Normal runtime changes
# live under XDG_CONFIG_HOME so Settings/screen-size never dirty the checkout.
# The generated user kitty.conf includes the tracked default file, which means
# new defaults arrive on update without overwriting user overrides.  The
# KILIX_CONFIG_DIRECTORY override remains available for tests/custom packaging.
KILIX_DEFAULT_CONFIG_DIRECTORY="$KILIX_HOME/config"
KILIX_USER_CONFIG_DIRECTORY="${XDG_CONFIG_HOME:-$HOME/.config}/kilix"
KILIX_STATE_DIRECTORY="${XDG_STATE_HOME:-$HOME/.local/state}/kilix"
_KILIX_DEFAULTS_LINK="$KILIX_USER_CONFIG_DIRECTORY/.kilix-defaults.conf"
_KILIX_CONFIG_MARKER="# Kilix user overrides. Tracked defaults are loaded first."

_kilix_write_migrated_kitty() {
  _source="$1" _target="$2" _tmp="$(mktemp "${2}.tmp.XXXXXX")"
  {
    printf '%s\n' "$_KILIX_CONFIG_MARKER" "include .kilix-defaults.conf"
    cat "$_source"
  } >"$_tmp"
  mv "$_tmp" "$_target"
}

_kilix_refresh_managed_link() {
  _target="$1" _source="$2"
  if [ -L "$_target" ]; then
    ln -sfn "$_source" "$_target"
  elif [ ! -e "$_target" ]; then
    ln -s "$_source" "$_target"
  fi
}

_kilix_refresh_generated_include() {
  _target="$1"
  [ -f "$_target" ] || return 0
  grep -qF "$_KILIX_CONFIG_MARKER" "$_target" 2>/dev/null || return 0
  _tmp="$(mktemp "${_target}.tmp.XXXXXX")"
  awk -v marker="$_KILIX_CONFIG_MARKER" '
    $0 == marker { managed=1; print; next }
    managed && !done && /^include / {
      print "include .kilix-defaults.conf"; done=1; next
    }
    { print }
    END { if (!done) print "include .kilix-defaults.conf" }
  ' "$_target" >"$_tmp"
  mv "$_tmp" "$_target"
}

_kilix_init_user_config() {
  mkdir -p "$KILIX_USER_CONFIG_DIRECTORY"
  _user_kitty="$KILIX_USER_CONFIG_DIRECTORY/kitty.conf"
  _user_env="$KILIX_USER_CONFIG_DIRECTORY/kilix.env"

  _kilix_refresh_managed_link "$_KILIX_DEFAULTS_LINK" \
    "$KILIX_DEFAULT_CONFIG_DIRECTORY/kitty.conf"

  if [ ! -e "$_user_kitty" ]; then
    if [ -d "$KILIX_HOME/.git" ] \
         && ! git -C "$KILIX_HOME" diff --quiet HEAD -- config/kitty.conf 2>/dev/null; then
      # Preserve settings written by releases that edited the tracked file.
      _kilix_write_migrated_kitty \
        "$KILIX_DEFAULT_CONFIG_DIRECTORY/kitty.conf" "$_user_kitty"
      _KILIX_MIGRATED_KITTY=1
      echo "kilix: migrated modified config/kitty.conf to $_user_kitty" >&2
    else
      printf '%s\n%s\n' "$_KILIX_CONFIG_MARKER" \
        'include .kilix-defaults.conf' >"$_user_kitty"
    fi
  fi
  _kilix_refresh_generated_include "$_user_kitty"
  if [ ! -e "$_user_env" ]; then
    if [ -d "$KILIX_HOME/.git" ] \
         && ! git -C "$KILIX_HOME" diff --quiet HEAD -- config/kilix.env 2>/dev/null; then
      cp "$KILIX_DEFAULT_CONFIG_DIRECTORY/kilix.env" "$_user_env"
      echo "kilix: migrated modified config/kilix.env to $_user_env" >&2
    else
      printf '%s\n' '# Kilix user runtime overrides (KEY=value; not shell code).' >"$_user_env"
    fi
  fi
  chmod 600 "$_user_kitty" "$_user_env" 2>/dev/null || true

  # Refresh managed symlinks on every launch so moving/reinstalling the checkout
  # does not strand the XDG configuration at an obsolete absolute path.
  for _icon in kitty.app.png kitty.app-128.png kilix-512.png; do
    _kilix_refresh_managed_link "$KILIX_USER_CONFIG_DIRECTORY/$_icon" \
      "$KILIX_DEFAULT_CONFIG_DIRECTORY/$_icon" 2>/dev/null || true
  done
}

_kilix_finish_config_migration() {
  # Only normalize a checkout whose *only* tracked changes are the two legacy
  # mutable config files. This preserves arbitrary developer/user work while
  # allowing old Settings-written checkouts to become safely updateable.
  [ -d "$KILIX_HOME/.git" ] || return 0
  _dirty_names="$(git -C "$KILIX_HOME" diff --name-only HEAD -- 2>/dev/null || true)"
  [ -n "$_dirty_names" ] || return 0
  while IFS= read -r _dirty_name; do
    case "$_dirty_name" in
      config/kitty.conf|config/kilix.env) ;;
      *) return 0 ;;
    esac
  done <<EOF
$_dirty_names
EOF

  for _rel in config/kitty.conf config/kilix.env; do
    git -C "$KILIX_HOME" diff --quiet HEAD -- "$_rel" 2>/dev/null && continue
    _source="$KILIX_HOME/$_rel"
    case "$_rel" in
      config/kitty.conf)
        _target="$KILIX_USER_CONFIG_DIRECTORY/kitty.conf"
        if cmp -s "$_source" "$_target"; then
          _kilix_write_migrated_kitty "$_source" "$_target"
        elif [ "${_KILIX_MIGRATED_KITTY:-0}" != 1 ]; then
          _backup="$KILIX_USER_CONFIG_DIRECTORY/source-tree-kitty.conf"
          cp "$_source" "$_backup"
          printf '\n# Settings migrated from the old source tree.\ninclude source-tree-kitty.conf\n' \
            >>"$_target"
        fi ;;
      config/kilix.env)
        _target="$KILIX_USER_CONFIG_DIRECTORY/kilix.env"
        if ! cmp -s "$_source" "$_target"; then
          {
            printf '\n%s\n' '# Settings migrated from the old source tree.'
            cat "$_source"
          } >>"$_target"
        fi ;;
    esac
    # The active XDG copy now contains the old settings. Reset only this known
    # legacy file/index entry, then restore the committed bytes atomically.
    git -C "$KILIX_HOME" reset -q HEAD -- "$_rel" || return 1
    _tmp="$(mktemp "${_source}.tmp.XXXXXX")" || return 1
    if ! git -C "$KILIX_HOME" show "HEAD:$_rel" >"$_tmp"; then
      rm -f "$_tmp"; return 1
    fi
    chmod --reference="$_source" "$_tmp" 2>/dev/null || chmod 0644 "$_tmp"
    mv "$_tmp" "$_source"
    echo "kilix: completed source-tree settings migration for $_rel" >&2
  done
}

if [ -n "${KILIX_CONFIG_DIRECTORY:-}" ]; then
  export KITTY_CONFIG_DIRECTORY="$KILIX_CONFIG_DIRECTORY"
else
  _kilix_init_user_config
  export KITTY_CONFIG_DIRECTORY="$KILIX_USER_CONFIG_DIRECTORY"
fi
export KILIX_ENV_CONFIG="${KILIX_ENV_CONFIG:-$KITTY_CONFIG_DIRECTORY/kilix.env}"

# Older Pleb releases left their fork-build marker in this checkout. Preserve
# it under XDG state so it no longer dirties or pollutes source trees.
if [ -f "$KILIX_HOME/.kilix-fork-built-ref" ] \
     && [ ! -e "$KILIX_STATE_DIRECTORY/fork-built-ref" ]; then
  mkdir -p "$KILIX_STATE_DIRECTORY"
  mv "$KILIX_HOME/.kilix-fork-built-ref" \
     "$KILIX_STATE_DIRECTORY/fork-built-ref" 2>/dev/null \
    || cp -p "$KILIX_HOME/.kilix-fork-built-ref" \
       "$KILIX_STATE_DIRECTORY/fork-built-ref" 2>/dev/null || true
fi

_kilix_load_env_file() {
  _conf="$1"
  [ -f "$_conf" ] || return 0
  while IFS= read -r _line || [ -n "$_line" ]; do
    _line="${_line%$'\r'}"
    case "$_line" in ''|\#*) continue ;; esac
    case "$_line" in *=*) ;; *) continue ;; esac
    _key="${_line%%=*}"
    _val="${_line#*=}"
    case "$_key" in
      KILIX_CHROME_CLOCK|KILIX_CHROME_CLOCK_FORMAT|KILIX_CHROME_BATTERY|KILIX_BATTERY_SUPPLY_DIR|\
      KILIX_DESKTOP_PROVIDER|KILIX_DESKTOP_COMMAND|KILIX_DESKTOP_NAME|KILIX_DESKTOP_FLAVOR|KILIX_DESKTOP_DIR|\
      KILIX95_AUTO_INSTALL|KILIX95_DIR|KILIX95_REPO|KILIX95_BRANCH|KILIX95_REF|KILIX95_TRUST_EXISTING_CHECKOUT|\
      KILIX95_ALLOW_MUTABLE_REF|KILIX95_ALLOW_UNPINNED_INSTALL|\
      KILIX_RECYCLE_DIR|KILIX_SAVER_IDLE|KILIX_HOST_CLIP|KILIX_NO_SOUND|KILIX_XPANE_WM|\
      KILIX_RUN_AUTO_FIT|KILIX_NO_PANE|KILIX_DEBUG|KILIX_HW|KILIX_BROWSE_LOG|KILIX_RUN_LOG|\
      KILIX_XFONTS|KILIX_BRIDGE_TOKEN|KILIX_SHELL_INTEGRATION|\
      KILIX_REF|KILIX_REPO|KILIX_TRUST_EXISTING_CHECKOUT|KILIX_ALLOW_MUTABLE_REF|\
      KILIX_PREBUILT_VERSION|KILIX_PREBUILT_SHA256|KILIX_ALLOW_UNVERIFIED_PREBUILT|\
      KILIX_BUILD_MODE|KILIX_KITTY_DEPS_URL|KILIX_KITTY_DEPS_SHA256|\
      KILIX_NERD_FONT_URL|KILIX_NERD_FONT_SHA256|KILIX_NERD_FONT_FILE_SHA256|KILIX_GO_TOOLCHAIN)
        export "$_key=$_val" ;;
    esac
  done < "$_conf"
}
_kilix_load_env_file "$KILIX_DEFAULT_CONFIG_DIRECTORY/kilix.env"
[ "$KILIX_ENV_CONFIG" = "$KILIX_DEFAULT_CONFIG_DIRECTORY/kilix.env" ] \
  || _kilix_load_env_file "$KILIX_ENV_CONFIG"

# No-sudo streaming deps (Xvfb / Xvnc / vncpasswd / python-xlib unpacked by
# scripts/install-stream-deps.sh on hosts that lack them): pull in their
# PATH / LD_LIBRARY_PATH / PYTHONPATH so the serve modes find them. A no-op
# where the deps are already system-installed (the file won't exist).
_kx_env="${XDG_DATA_HOME:-$HOME/.local/share}/kilix/stream-env.sh"
if [ -f "$_kx_env" ]; then
  # shellcheck disable=SC1090
  . "$_kx_env"
fi

case "${1:-}" in
  # build.sh is invoked from the checkout root everywhere: it is cwd-independent
  # today, but running it from the caller's directory would let any future
  # cwd-relative path in it touch an unrelated tree.
  --build) shift; cd "$KILIX_HOME"; exec "$KILIX_HOME/build.sh" "$@" ;;
  --kilix-version|kilix-version)
    # The Plebian-OS release version of this kilix checkout. (Plain `--version`
    # is passed through to the kitty engine by --which/exec, so this is a
    # distinct flag for the launcher's own version.)
    cat "$KILIX_HOME/VERSION" 2>/dev/null || echo unknown
    exit 0 ;;
  status|--status)
    _status_version="$(cat "$KILIX_HOME/VERSION" 2>/dev/null || echo unknown)"
    _status_head="$(git -C "$KILIX_HOME" rev-parse --short HEAD 2>/dev/null || echo not-a-checkout)"
    _status_dirty=clean
    git -C "$KILIX_HOME" diff --quiet --ignore-submodules=none HEAD -- 2>/dev/null \
      || _status_dirty=modified
    if [ -x "$FORK" ]; then _status_engine="$FORK"
    elif [ -x "$PREBUILT" ]; then _status_engine="$PREBUILT"
    else _status_engine=missing
    fi
    _status_provider="${KILIX_DESKTOP_PROVIDER:-auto}"
    _status_provider_dir="${KILIX95_DIR:-$HOME/kilix-95}"
    case "$_status_provider" in
      auto)
        if [ -f "$_status_provider_dir/main.py" ]; then
          _status_provider="external (authoritative)"
        else
          _status_provider="builtin (compatibility fallback; external absent)"
          _status_provider_dir="$KILIX_HOME/desktop"
        fi ;;
      builtin)
        _status_provider_dir="$KILIX_HOME/desktop"
        ;;
      command|custom|none|off|disabled)
        _status_provider_dir=""
        ;;
    esac
    printf '%s\n' \
      "kilix $_status_version ($_status_head, $_status_dirty)" \
      "engine: $_status_engine" \
      "config: $KITTY_CONFIG_DIRECTORY/kitty.conf" \
      "runtime config: $KILIX_ENV_CONFIG" \
      "desktop provider: $_status_provider" \
      "desktop path: ${_status_provider_dir:-n/a}"
    if [ -n "$_status_provider_dir" ] && [ -f "$_status_provider_dir/main.py" ]; then
      python3 "$KILIX_HOME/scripts/check-desktop-provider.py" \
        "$_status_provider_dir" || exit $?
    fi
    exit 0 ;;
  update|--update)
    # Update only from the expected origin, only from a clean checkout, and
    # only by an explicit origin fast-forward or detached ref checkout.
    if ! command -v git >/dev/null 2>&1; then
      echo "kilix update: git not found" >&2; exit 1
    fi
    if [ ! -d "$KILIX_HOME/.git" ]; then
      echo "kilix update: $KILIX_HOME is not a git checkout — nothing to pull" >&2
      exit 1
    fi
    _expected_origin="${KILIX_REPO:-https://github.com/itsmygithubacct/kilix.git}"
    _actual_origin="$(git -C "$KILIX_HOME" config --get remote.origin.url 2>/dev/null || true)"
    if [ -z "$_actual_origin" ]; then
      echo "kilix update: checkout has no origin remote" >&2; exit 1
    fi
    if [ "$_actual_origin" != "$_expected_origin" ] \
         && [ "${KILIX_TRUST_EXISTING_CHECKOUT:-0}" != 1 ]; then
      echo "kilix update: origin is '$_actual_origin', expected '$_expected_origin'" >&2
      echo "kilix update: set KILIX_TRUST_EXISTING_CHECKOUT=1 only if you trust it" >&2
      exit 1
    fi
    _kilix_finish_config_migration \
      || { echo "kilix update: could not complete legacy config migration" >&2; exit 1; }
    if [ -n "$(git -C "$KILIX_HOME" status --porcelain --untracked-files=normal 2>/dev/null)" ]; then
      echo "kilix update: refusing to overwrite a modified checkout" >&2
      echo "kilix update: user settings belong in $KILIX_USER_CONFIG_DIRECTORY" >&2
      exit 1
    fi
    _before="$(git -C "$KILIX_HOME" rev-parse HEAD 2>/dev/null || echo unknown)"
    _before_branch="$(git -C "$KILIX_HOME" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
    _src_before="$(git -C "$KILIX_HOME/src" rev-parse HEAD 2>/dev/null || echo none)"
    _kilix_rollback_sources() {
      if [ -n "$_before_branch" ]; then
        if git -C "$KILIX_HOME" symbolic-ref --quiet HEAD >/dev/null 2>&1; then
          git -C "$KILIX_HOME" reset --keep "$_before" || return 1
        else
          git -C "$KILIX_HOME" checkout "$_before_branch" || return 1
        fi
      else
        git -C "$KILIX_HOME" checkout --detach "$_before" || return 1
      fi
      git -C "$KILIX_HOME" submodule update --init --recursive
    }
    if [ -n "${KILIX_REF:-}" ]; then
      if ! [[ "$KILIX_REF" =~ ^[0-9a-fA-F]{40}$ ]] \
           && [ "${KILIX_ALLOW_MUTABLE_REF:-0}" != 1 ]; then
        echo "kilix update: KILIX_REF must be a full commit SHA" >&2
        echo "kilix update: set KILIX_ALLOW_MUTABLE_REF=1 only to trust a mutable tag/branch" >&2
        exit 1
      fi
      echo "kilix update: fetching ref $KILIX_REF from origin"
      git -C "$KILIX_HOME" fetch --tags --prune origin "$KILIX_REF" || exit $?
      _target="$(git -C "$KILIX_HOME" rev-parse --verify 'FETCH_HEAD^{commit}')" \
        || { echo "kilix update: $KILIX_REF did not resolve to a commit" >&2; exit 1; }
      git -C "$KILIX_HOME" checkout --detach "$_target" || exit $?
    else
      _branch="$(git -C "$KILIX_HOME" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
      if [ -z "$_branch" ]; then
        echo "kilix update: detached checkout requires KILIX_REF" >&2; exit 1
      fi
      _upstream="$(git -C "$KILIX_HOME" rev-parse --abbrev-ref '@{upstream}' 2>/dev/null || true)"
      if [ "$_upstream" != "origin/$_branch" ]; then
        echo "kilix update: branch $_branch must track origin/$_branch (found ${_upstream:-none})" >&2
        exit 1
      fi
      echo "kilix update: fetching origin/$_branch"
      git -C "$KILIX_HOME" fetch --prune origin "$_branch" || exit $?
      git -C "$KILIX_HOME" merge --ff-only "origin/$_branch" || exit $?
    fi
    if ! git -C "$KILIX_HOME" submodule update --init --recursive; then
      echo "kilix update: submodule update failed; rolling sources back" >&2
      _kilix_rollback_sources \
        || echo "kilix update: WARNING: automatic source rollback failed" >&2
      exit 1
    fi
    _after="$(git -C "$KILIX_HOME" rev-parse HEAD 2>/dev/null || echo unknown)"
    _src_after="$(git -C "$KILIX_HOME/src" rev-parse HEAD 2>/dev/null || echo none)"
    _fork_stamp="$KILIX_STATE_DIRECTORY/fork-built-ref"
    _fork_stamp_wanted="$KILIX_HOME"$'\t'"$_src_after"
    _fork_stamped="$(cat "$_fork_stamp" 2>/dev/null || true)"
    _fork_needs_rebuild=0
    if [ -x "$FORK" ]; then
      if [ "$_src_after" = none ]; then
        [ "$_before" = "$_after" ] || _fork_needs_rebuild=1
      elif [ "$_fork_stamped" != "$_fork_stamp_wanted" ]; then
        _fork_needs_rebuild=1
      fi
    fi
    if [ "$_fork_needs_rebuild" = 1 ]; then
      mkdir -p "$KILIX_STATE_DIRECTORY"
      _engine_backup="$(mktemp -d "$KILIX_STATE_DIRECTORY/update-engine.XXXXXX")"
      mkdir -p "$_engine_backup/src"
      _engine_manifest="$_engine_backup/manifest"
      : >"$_engine_manifest"
      for _engine_file in \
        "$KILIX_HOME/src/kitty/launcher/kitty" \
        "$KILIX_HOME/src/kitty/launcher/kitten"; do
        [ ! -f "$_engine_file" ] || printf '%s\n' "${_engine_file#"$KILIX_HOME/src/"}" \
          >>"$_engine_manifest"
      done
      find "$KILIX_HOME/src/kitty" -maxdepth 1 -type f -name '*.so' -printf 'kitty/%f\n' \
        >>"$_engine_manifest" 2>/dev/null || true
      find "$KILIX_HOME/src/kittens" -type f -name '*.so' -printf 'kittens/%P\n' \
        >>"$_engine_manifest" 2>/dev/null || true
      while IFS= read -r _engine_rel; do
        [ -n "$_engine_rel" ] || continue
        mkdir -p "$_engine_backup/src/$(dirname "$_engine_rel")"
        cp -p "$KILIX_HOME/src/$_engine_rel" \
          "$_engine_backup/src/$_engine_rel"
      done <"$_engine_manifest"
      [ ! -e "$_fork_stamp" ] || cp -p "$_fork_stamp" "$_engine_backup/fork-built-ref"

      _kilix_update_rollback() {
        echo "kilix update: rolling sources and engine back to $_before" >&2
        _kilix_rollback_sources || return 1
        find "$KILIX_HOME/src/kitty" -maxdepth 1 -type f -name '*.so' -delete \
          2>/dev/null || true
        find "$KILIX_HOME/src/kittens" -type f -name '*.so' -delete \
          2>/dev/null || true
        rm -f "$KILIX_HOME/src/kitty/launcher/kitty" \
          "$KILIX_HOME/src/kitty/launcher/kitten"
        if [ -d "$_engine_backup/src" ]; then
          cp -a "$_engine_backup/src/." "$KILIX_HOME/src/"
        fi
        if [ -f "$_engine_backup/fork-built-ref" ]; then
          cp -p "$_engine_backup/fork-built-ref" "$_fork_stamp"
        else
          rm -f "$_fork_stamp"
        fi
      }

      if command -v go >/dev/null 2>&1; then
        echo "kilix update: rebuilding existing fork engine"
        if ! (cd "$KILIX_HOME" && "$KILIX_HOME/build.sh"); then
          echo "kilix update: fork rebuild failed" >&2
          _kilix_update_rollback \
            || echo "kilix update: WARNING: automatic rollback failed" >&2
          rm -rf "$_engine_backup"
          exit 1
        fi
      else
        echo "kilix update: Go not found; cannot rebuild the changed fork engine" >&2
        _kilix_update_rollback \
          || echo "kilix update: WARNING: automatic rollback failed" >&2
        rm -rf "$_engine_backup"
        exit 1
      fi
      if [ "$_src_after" != none ]; then
        _stamp_tmp="$(mktemp "$KILIX_STATE_DIRECTORY/fork-built-ref.tmp.XXXXXX")"
        printf '%s\n' "$_fork_stamp_wanted" >"$_stamp_tmp"
        mv "$_stamp_tmp" "$_fork_stamp"
      fi
      rm -rf "$_engine_backup"
    fi
    echo "kilix update: done — restart 'kilix desktop' to load the changes."
    exit 0 ;;
  --which)
    for b in "$FORK" "$PREBUILT"; do
      [ -x "$b" ] && { echo "$b"; exec "$b" --version; }
    done
    echo "no kitty built yet — run: $KILIX_HOME/kilix --build" >&2; exit 1 ;;
  --install-desktop)
    # Desktop entry + themed icon so kilix groups separately in the taskbar
    # (StartupWMClass matches the WM_CLASS set by --class below) and can be
    # pinned/launched from the app menu with its own icon.
    apps="${XDG_DATA_HOME:-$HOME/.local/share}/applications"
    icons="${XDG_DATA_HOME:-$HOME/.local/share}/icons/hicolor"
    for _i in kitty.app-128.png kitty.app.png kilix-512.png; do
      [ -f "$KILIX_HOME/config/$_i" ] || { echo "kilix: missing icon $KILIX_HOME/config/$_i" >&2; exit 1; }
    done
    mkdir -p "$apps" "$icons/128x128/apps" "$icons/256x256/apps" "$icons/512x512/apps"
    cp "$KILIX_HOME/config/kitty.app-128.png" "$icons/128x128/apps/kilix.png"
    cp "$KILIX_HOME/config/kitty.app.png"     "$icons/256x256/apps/kilix.png"
    cp "$KILIX_HOME/config/kilix-512.png"     "$icons/512x512/apps/kilix.png"
    cat > "$apps/kilix.desktop" <<EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=kilix
GenericName=Terminal Emulator
Comment=Tilix-styled kitty with clickable pane buttons
Exec="$KILIX_HOME/kilix"
Icon=kilix
Terminal=false
Categories=System;TerminalEmulator;
StartupWMClass=kilix
StartupNotify=true
EOF
    if command -v update-desktop-database >/dev/null; then
      update-desktop-database "$apps" || true
    fi
    if command -v gtk-update-icon-cache >/dev/null; then
      gtk-update-icon-cache -f -t "$icons" 2>/dev/null || true
    fi
    echo "installed: $apps/kilix.desktop (+ hicolor icons). Log out/in or restart your panel if the icon doesn't show immediately."
    exit 0 ;;
esac

if [ -x "$FORK" ]; then
  BIN="$FORK"                                     # prefer the clickable-chrome fork
elif [ -x "$PREBUILT" ]; then
  BIN="$PREBUILT"                                 # fall back to the prebuilt binary
elif [ "${1:-}" = "screen-size" ] || [ "${1:-}" = "font-size" ]; then
  BIN=""                                          # config-only command; no bootstrap side effect
else
  # nothing available yet: try building the fork, else pull the prebuilt binary
  if (cd "$KILIX_HOME" && "$KILIX_HOME/build.sh"); then BIN="$FORK"; else "$KILIX_HOME/bootstrap.sh"; BIN="$PREBUILT"; fi
fi
[ -z "${BIN:-}" ] || [ -x "$BIN" ] || { echo "kilix: no runnable kitty (build and bootstrap both failed)" >&2; exit 1; }

case "${1:-}" in
  # kitty subcommands (kitty +kitten icat …): + must be kitty's first arg,
  # so forward without --class.
  +*) exec "$BIN" "$@" ;;
esac

KITTEN="${KILIX_KITTEN:-}"
[ -n "${BIN:-}" ] && KITTEN="$(dirname "$BIN")/kitten"

_kilix_desktop_die() {
  echo "kilix desktop: $*" >&2
  exit 1
}

_kilix_remote_control() {
  [ -x "$KITTEN" ] || { echo "kilix $1: kitten not found next to $BIN" >&2; exit 1; }
  if [ -z "${KITTY_LISTEN_ON:-}" ]; then
    echo "kilix $1: no live kilix remote-control socket (run this inside kilix, or set KITTY_LISTEN_ON)" >&2
    exit 1
  fi
  KILIX_KITTEN="$KITTEN" exec python3 "$KILIX_HOME/config/remote.py" "$@"
}

_kilix_restore_pane_tty() {
  # pop kbd protocol; disable mouse (btn-event/SGR/pixels) + bracketed paste;
  # re-enable autowrap; delete all images; show cursor; leave alt screen. Each
  # code is a no-op if the pane app already restored it.
  printf '\033[<u\033[?1002l\033[?1003l\033[?1006l\033[?1016l\033[?2004l\033[?7h\033_Ga=d,d=A\033\\\033[?25h\033[?1049l'
  stty sane 2>/dev/null || true
}

_kilix_screen_size_usage() {
  cat >&2 <<EOF
usage: $_self screen-size [show|larger [STEP]|smaller [STEP]|reset|set POINTS|+POINTS|-POINTS|POINTS]

Adjusts Kilix's terminal scale by changing kitty's font_size. Larger text means
fewer terminal rows/columns fit on the same fullscreen display; smaller text
means more rows/columns fit.
EOF
}

_kilix_screen_size_config() {
  printf '%s\n' "${KITTY_CONFIG_DIRECTORY:-$KILIX_HOME/config}/kitty.conf"
}

_kilix_screen_size_current() {
  _conf="$(_kilix_screen_size_config)"
  if [ -f "$_conf" ]; then
    awk '$1 == "font_size" { v = $2 } END { if (v != "") print v; else print "11.0" }' "$_conf"
  else
    printf '11.0\n'
  fi
}

_kilix_screen_size_format() {
  awk -v v="$1" 'BEGIN {
    if (v < 4) v = 4;
    if (v > 110) v = 110;
    if (v == int(v)) printf "%d\n", v;
    else {
      s = sprintf("%.2f", v);
      sub(/0+$/, "", s);
      sub(/[.]$/, "", s);
      print s;
    }
  }'
}

_kilix_screen_size_calc() {
  awk -v cur="$1" -v delta="$2" 'BEGIN { printf "%.4f\n", cur + delta }' \
    | while IFS= read -r _v; do _kilix_screen_size_format "$_v"; done
}

_kilix_screen_size_valid() {
  awk -v v="$1" 'BEGIN { exit !(v ~ /^[0-9]+([.][0-9]+)?$/ && v + 0 >= 4 && v + 0 <= 110) }'
}

_kilix_screen_size_step_valid() {
  awk -v v="$1" 'BEGIN { exit !(v ~ /^[0-9]+([.][0-9]+)?$/) }'
}

_kilix_screen_size_write_config() {
  _size="$1"
  _conf="$(_kilix_screen_size_config)"
  _line="$(printf '%-30s %s' font_size "$_size")"
  mkdir -p "$(dirname "$_conf")"
  _tmp="$(mktemp)" || return 1
  if [ -f "$_conf" ]; then
    awk -v line="$_line" '
      { lines[NR] = $0 }
      $1 == "font_size" { last = NR }
      END {
        if (NR == 0) {
          print "# -- kilix screen-size --";
          print line;
          exit;
        }
        for (i = 1; i <= NR; i++) {
          if (i == last) print line;
          else print lines[i];
        }
        if (!last) {
          print "";
          print "# -- kilix screen-size --";
          print line;
        }
      }' "$_conf" >"$_tmp"
  else
    printf '%s\n%s\n' "# -- kilix screen-size --" "$_line" >"$_tmp"
  fi
  mv "$_tmp" "$_conf"
}

_kilix_screen_size_apply_live() {
  _size="$1"
  if [ -n "${KITTY_LISTEN_ON:-}" ] && [ -x "$KITTEN" ]; then
    "$KITTEN" @ action load_config_file >/dev/null 2>&1 || true
    "$KITTEN" @ set-font-size --all "$_size" >/dev/null 2>&1 || true
  elif [ -n "${KITTY_PID:-}" ] && [[ "$KITTY_PID" =~ ^[0-9]+$ ]]; then
    kill -USR1 "$KITTY_PID" 2>/dev/null || true
  fi
}

_kilix_screen_size_cmd() {
  _action="${1:-show}"
  [ $# -gt 0 ] && shift
  _cur="$(_kilix_screen_size_current)"
  case "$_action" in
    show|status|get)
      printf 'font_size %s\n' "$_cur"
      return 0 ;;
    larger|increase|up|plus)
      _step="${1:-2}"
      [ $# -le 1 ] || { _kilix_screen_size_usage; return 2; }
      _kilix_screen_size_step_valid "$_step" || { _kilix_screen_size_usage; return 2; }
      _new="$(_kilix_screen_size_calc "$_cur" "$_step")" ;;
    smaller|decrease|down|minus)
      _step="${1:-2}"
      [ $# -le 1 ] || { _kilix_screen_size_usage; return 2; }
      _kilix_screen_size_step_valid "$_step" || { _kilix_screen_size_usage; return 2; }
      _new="$(_kilix_screen_size_calc "$_cur" "-$_step")" ;;
    reset|default)
      [ $# -eq 0 ] || { _kilix_screen_size_usage; return 2; }
      _new="11.0" ;;
    set)
      [ $# -eq 1 ] || { _kilix_screen_size_usage; return 2; }
      _kilix_screen_size_valid "$1" || { _kilix_screen_size_usage; return 2; }
      _new="$1" ;;
    +*)
      [ $# -eq 0 ] || { _kilix_screen_size_usage; return 2; }
      _step="${_action#+}"
      _kilix_screen_size_step_valid "$_step" || { _kilix_screen_size_usage; return 2; }
      _new="$(_kilix_screen_size_calc "$_cur" "$_step")" ;;
    -h|--help|help)
      _kilix_screen_size_usage
      return 0 ;;
    -*)
      [ $# -eq 0 ] || { _kilix_screen_size_usage; return 2; }
      _step="${_action#-}"
      _kilix_screen_size_step_valid "$_step" || { _kilix_screen_size_usage; return 2; }
      _new="$(_kilix_screen_size_calc "$_cur" "-$_step")" ;;
    [0-9]*)
      [ $# -eq 0 ] || { _kilix_screen_size_usage; return 2; }
      _kilix_screen_size_valid "$_action" || { _kilix_screen_size_usage; return 2; }
      _new="$_action" ;;
    *)
      _kilix_screen_size_usage
      return 2 ;;
  esac
  _new="$(_kilix_screen_size_format "$_new")"
  if ! _kilix_screen_size_valid "$_new"; then
    echo "kilix screen-size: font size must be between 4 and 110 points" >&2
    return 2
  fi
  _kilix_screen_size_write_config "$_new"
  _kilix_screen_size_apply_live "$_new"
  printf 'font_size %s\n' "$_new"
}

case "${1:-}" in
  ls|focus|watch)
    _remote_cmd="$1"; shift
    _kilix_remote_control "$_remote_cmd" "$@" ;;
  screen-size|font-size)
    _remote_cmd="$1"; shift
    _kilix_screen_size_cmd "$@"
    exit $? ;;
esac

_kilix95_checkout_ref() {
  [ -n "${KILIX95_REF:-}" ] || return 0
  if ! [[ "$KILIX95_REF" =~ ^[0-9a-fA-F]{40}$ ]]; then
    [ "${KILIX95_ALLOW_MUTABLE_REF:-0}" = 1 ] \
      || _kilix_desktop_die "KILIX95_REF must be a full 40-character commit SHA (set KILIX95_ALLOW_MUTABLE_REF=1 to trust a mutable tag/branch)"
  fi
  if [ -n "$(git -C "$_k95_dir" status --porcelain --untracked-files=normal 2>/dev/null)" ]; then
    _kilix_desktop_die "ref checkout refused because $_k95_dir has local modifications"
  fi
  git -C "$_k95_dir" fetch --force origin "$KILIX95_REF" \
    || _kilix_desktop_die "could not fetch KILIX95_REF=$KILIX95_REF"
  _k95_target="$(git -C "$_k95_dir" rev-parse --verify 'FETCH_HEAD^{commit}')" \
    || _kilix_desktop_die "KILIX95_REF did not resolve to a commit"
  git -C "$_k95_dir" checkout --detach "$_k95_target" \
    || _kilix_desktop_die "could not check out KILIX95_REF=$KILIX95_REF"
}

_kilix_desktop_validate() {
  python3 "$KILIX_HOME/scripts/check-desktop-provider.py" "$1" \
    || _kilix_desktop_die "provider contract validation failed for $1"
}

_kilix95_ensure_external() {
  _k95_dir="${KILIX95_DIR:-$HOME/kilix-95}"
  _k95_repo="${KILIX95_REPO:-https://github.com/itsmygithubacct/kilix-95.git}"

  if [ -f "$_k95_dir/main.py" ]; then
    if [ -d "$_k95_dir/.git" ]; then
      _k95_origin="$(git -C "$_k95_dir" config --get remote.origin.url 2>/dev/null || true)"
      if [ "$_k95_origin" != "$_k95_repo" ] \
           && [ "${KILIX95_TRUST_EXISTING_CHECKOUT:-0}" != 1 ]; then
        _kilix_desktop_die "$_k95_dir has origin '${_k95_origin:-missing}', expected '$_k95_repo' (set KILIX95_TRUST_EXISTING_CHECKOUT=1 to override)"
      fi
      _kilix95_checkout_ref
    elif [ "${KILIX95_TRUST_EXISTING_CHECKOUT:-0}" != 1 ]; then
      _kilix_desktop_die "$_k95_dir is not a git checkout (set KILIX95_TRUST_EXISTING_CHECKOUT=1 only for trusted packaged providers)"
    fi
    if [ -z "${KILIX95_REF:-}" ]; then
      echo "kilix desktop: WARNING: external provider is not pinned; set KILIX95_REF to its full commit SHA for reproducible launches" >&2
    fi
    _kilix_desktop_validate "$_k95_dir"
    _KILIX_DESKTOP_MAIN="$_k95_dir/main.py"
    _KILIX_DESKTOP_MODE=python
    return 0
  fi
  if [ "${KILIX95_AUTO_INSTALL:-0}" != 1 ]; then
    _kilix_desktop_die "Kilix 95 is not installed at $_k95_dir; set KILIX95_AUTO_INSTALL=1 to clone $_k95_repo"
  fi
  if [ -e "$_k95_dir" ] && [ ! -d "$_k95_dir/.git" ]; then
    _kilix_desktop_die "$_k95_dir exists but is not a Kilix 95 checkout"
  fi
  command -v git >/dev/null 2>&1 || _kilix_desktop_die "git is required to clone Kilix 95"
  if [ -z "${KILIX95_REF:-}" ] \
       && [ "${KILIX95_ALLOW_UNPINNED_INSTALL:-0}" != 1 ]; then
    _kilix_desktop_die "automatic provider install requires an immutable KILIX95_REF commit SHA (or explicit KILIX95_ALLOW_UNPINNED_INSTALL=1)"
  fi

  echo "kilix desktop: cloning Kilix 95 -> $_k95_dir" >&2
  _clone_args=()
  [ -n "${KILIX95_BRANCH:-}" ] && _clone_args=(--branch "$KILIX95_BRANCH")
  git clone "${_clone_args[@]}" "$_k95_repo" "$_k95_dir" \
    || _kilix_desktop_die "git clone failed ($_k95_repo)"
  _kilix95_checkout_ref
  [ -f "$_k95_dir/main.py" ] || _kilix_desktop_die "missing main.py in $_k95_dir"
  if [ -z "${KILIX95_REF:-}" ]; then
    echo "kilix desktop: WARNING: installed provider is unpinned by explicit override" >&2
  fi
  _kilix_desktop_validate "$_k95_dir"
  _KILIX_DESKTOP_MAIN="$_k95_dir/main.py"
  _KILIX_DESKTOP_MODE=python
}

_kilix_desktop_select() {
  _KILIX_DESKTOP_MAIN=
  _KILIX_DESKTOP_MODE=
  _k95_provider="${KILIX_DESKTOP_PROVIDER:-auto}"
  _k95_builtin="$KILIX_HOME/desktop/main.py"

  case "$_k95_provider" in
    none|off|disabled)
      _KILIX_DESKTOP_MODE=none ;;
    command|custom)
      [ -n "${KILIX_DESKTOP_COMMAND:-}" ] \
        || _kilix_desktop_die "KILIX_DESKTOP_PROVIDER=$_k95_provider requires KILIX_DESKTOP_COMMAND"
      _KILIX_DESKTOP_MODE="command" ;;
    builtin)
      [ -f "$_k95_builtin" ] || _kilix_desktop_die "built-in desktop is not present at $_k95_builtin"
      _kilix_desktop_validate "$KILIX_HOME/desktop"
      _KILIX_DESKTOP_MAIN="$_k95_builtin"
      _KILIX_DESKTOP_MODE=python ;;
    external)
      _kilix95_ensure_external ;;
    auto)
      _auto_external="${KILIX95_DIR:-$HOME/kilix-95}"
      if [ -f "$_auto_external/main.py" ]; then
        _kilix95_ensure_external
      elif [ -f "$_k95_builtin" ]; then
        echo "kilix desktop: external authoritative provider not found; using the bundled compatibility fallback" >&2
        _kilix_desktop_validate "$KILIX_HOME/desktop"
        _KILIX_DESKTOP_MAIN="$_k95_builtin"
        _KILIX_DESKTOP_MODE=python
      else
        _kilix95_ensure_external
      fi ;;
    *)
      _kilix_desktop_die "unknown KILIX_DESKTOP_PROVIDER=$_k95_provider (use auto, builtin, external, command, or none)" ;;
  esac
}

# browse: Chrome (and video) rendered in a pane. Host it in its own overlay
# WINDOW so it gets a title bar with a clickable close button — closing the
# overlay exits the app and reveals the shell underneath, which is never
# taken over. Needs to be inside a kitty window with remote control
# (KITTY_LISTEN_ON, set by the allow_remote_control + listen_on config).
# KILIX_IN_OVERLAY guards against the re-launched instance overlaying again.
if [ "${1:-}" = "browse" ]; then
  shift
  if [ -z "${KILIX_IN_OVERLAY:-}" ] && [ -n "${KITTY_WINDOW_ID:-}" ] \
       && [ -n "${KITTY_LISTEN_ON:-}" ] && [ -x "$KITTEN" ]; then
    # Spawn the app as an overlay over the current window; the launcher then
    # exits and the shell returns to its prompt (hidden under the overlay
    # until it is closed). The overlay re-enters this launcher with
    # KILIX_IN_OVERLAY=1, taking the in-place branch below.
    exec "$KITTEN" @ launch --type=overlay --cwd=current \
      --env KILIX_IN_OVERLAY=1 --env "KILIX_STREAM=${KILIX_STREAM:-}" \
      -- "$_self" browse "$@"
  fi
  # In-place fallback: inside the overlay, or a terminal without remote
  # control. Run WRAPPED, not exec'd: if the app dies by signal (SIGKILL,
  # etc.) without running its own terminal cleanup, restore the tty here so
  # the shell stays usable. A clean exit (rc < 128) already cleaned up.
  rc=0
  if [ -x "$KITTEN" ] && "$KITTEN" --help 2>/dev/null \
       | sed -n '/^Commands:/,/^$/p' | grep -qFx "   browse"; then
    "$KITTEN" browse "$@" || rc=$?
  else
    python3 "$KILIX_HOME/config/browse.py" "$@" || rc=$?
  fi
  [ "$rc" -eq 0 ] || _kilix_restore_pane_tty
  exit "$rc"
fi

# run: an X11 app streamed into a pane (private Xvfb + x11grab + XTest).
# Python prototype only for now. Same wrapped-cleanup story as browse above,
# but the default target is a new TAB, not an overlay: the launching shell
# stays visible in its own tab and closing the app's tab exits the app. If
# the kitten dies by signal, restore the tty by hand.
if [ "${1:-}" = "run" ]; then
  shift
  if [ -z "${KILIX_IN_OVERLAY:-}" ] && [ -n "${KITTY_WINDOW_ID:-}" ] \
       && [ -n "${KITTY_LISTEN_ON:-}" ] && [ -x "$KITTEN" ]; then
    # Tab title: the first non-flag arg is the app command (--size/--fps
    # take a separate value in their unglued form, so skip it).
    _app=run; _skip=
    for _a in "$@"; do
      if [ -n "$_skip" ]; then _skip=; continue; fi
      case "$_a" in
        --size|--fps) _skip=1 ;;
        --*) ;;
        *) _app=${_a##*/}; break ;;
      esac
    done
    # KILIX_IN_OVERLAY doubles as the generic "already relaunched into our
    # own kitty window" guard, whatever the window type.
    exec "$KITTEN" @ launch --type=tab --cwd=current --tab-title "$_app" \
      --env KILIX_IN_OVERLAY=1 --env "KILIX_STREAM=${KILIX_STREAM:-}" \
      -- "$_self" run "$@"
  fi
  rc=0
  python3 "$KILIX_HOME/config/apprun.py" "$@" || rc=$?
  [ "$rc" -eq 0 ] || _kilix_restore_pane_tty
  exit "$rc"
fi

# desktop: a Windows 95-style desktop environment rendered as pixels in a
# kilix tab (start bar, launchers, file manager, Notepad, Settings that edits
# the kilix config live). Modules live in ./desktop/. Same host-in-own-tab +
# wrapped-cleanup story as run; quit via Start > Shut Down (or Ctrl+Alt+Q).
if [ "${1:-}" = "desktop" ]; then
  shift
  _kilix_desktop_select
  if [ -z "${KILIX_IN_OVERLAY:-}" ] && [ -n "${KITTY_WINDOW_ID:-}" ] \
       && [ -n "${KITTY_LISTEN_ON:-}" ] && [ -x "$KITTEN" ]; then
    # Only one kilix 95 desktop at a time: if one is already running in this
    # kitty, switch to it instead of opening a second — two desktops fight over
    # the graphics transport. Find the window whose foreground process is the
    # desktop (kitty's cmdline: match sees only the launch command, not the
    # python child, so ask @ ls and check foreground_processes) and focus it.
    _dwid=""
    if [ "$_KILIX_DESKTOP_MODE" = python ]; then
      _dwid="$(KILIX_DESKTOP_MAIN="$_KILIX_DESKTOP_MAIN" "$KITTEN" @ ls 2>/dev/null | python3 -c 'import json,os,sys
try: d=json.load(sys.stdin)
except Exception: sys.exit(0)
targets={os.environ.get("KILIX_DESKTOP_MAIN","")}
targets={t for t in targets if t}
def is_desktop_arg(a):
    return a in targets or a.endswith("/desktop/main.py") or a.endswith("/kilix-95/main.py")
ids=[w["id"] for o in d for t in o.get("tabs",[]) for w in t.get("windows",[]) if any(is_desktop_arg(a) for p in w.get("foreground_processes",[]) for a in p.get("cmdline",[]))]
print(ids[0] if ids else "")' 2>/dev/null)"
    fi
    if [ -n "$_dwid" ]; then
      "$KITTEN" @ focus-window --match "id:$_dwid" >/dev/null 2>&1
      exit 0
    fi
    exec "$KITTEN" @ launch --type=tab --cwd=current --tab-title "${KILIX_DESKTOP_NAME:-desktop}" \
      --env KILIX_IN_OVERLAY=1 --env "KILIX_STREAM=${KILIX_STREAM:-}" \
      --env "KILIX_DESKTOP_PROVIDER=${KILIX_DESKTOP_PROVIDER:-}" \
      --env "KILIX_DESKTOP_COMMAND=${KILIX_DESKTOP_COMMAND:-}" \
      --env "KILIX_DESKTOP_NAME=${KILIX_DESKTOP_NAME:-}" \
      --env "KILIX_DESKTOP_FLAVOR=${KILIX_DESKTOP_FLAVOR:-}" \
      --env "KILIX95_AUTO_INSTALL=${KILIX95_AUTO_INSTALL:-}" \
      --env "KILIX95_DIR=${KILIX95_DIR:-}" \
      --env "KILIX95_REPO=${KILIX95_REPO:-}" \
      --env "KILIX95_BRANCH=${KILIX95_BRANCH:-}" \
      --env "KILIX95_REF=${KILIX95_REF:-}" \
      -- "$_self" desktop "$@"
  fi
  rc=0
  case "$_KILIX_DESKTOP_MODE" in
    none)
      echo "kilix desktop: disabled by KILIX_DESKTOP_PROVIDER=$_k95_provider" >&2
      exit 0 ;;
    command)
      KILIX_HOME="$KILIX_HOME" KILIX_KITTEN="$KITTEN" \
        sh -c "$KILIX_DESKTOP_COMMAND" "${KILIX_DESKTOP_NAME:-desktop}" "$@" || rc=$? ;;
    python)
      KILIX_HOME="$KILIX_HOME" KILIX95_HOME="$(dirname "$_KILIX_DESKTOP_MAIN")" \
        KILIX_KITTEN="$KITTEN" python3 "$_KILIX_DESKTOP_MAIN" "$@" || rc=$? ;;
    *)
      _kilix_desktop_die "internal error: no desktop mode selected" ;;
  esac
  [ "$rc" -eq 0 ] || _kilix_restore_pane_tty
  exit "$rc"
fi

# share: run the WHOLE kilix on a headless display and stream it to multiple
# devices (Phase 3). Pixels go out as HLS (any browser/player, many viewers);
# a remote viewer's keyboard/mouse are injected with XTest. Runs in the current
# pane, printing connect instructions; Ctrl+C stops it. Loopback by default;
# `--lan` serves the LAN over TLS + token. `--size WxH` sets the virtual screen.
# (This was `kilix desktop` before the desktop environment claimed that name.)
if [ "${1:-}" = "share" ]; then
  shift
  KILIX_KITTY="$BIN" exec python3 "$KILIX_HOME/config/share.py" "$@"
fi

# mux: open a kilix tab that is backed by the private tmux server from the
# start. Unlike `kilix watch`, this is real terminal multiplexing: attach/view
# can reconnect to it later because the shell is born inside tmux.
if [ "${1:-}" = "mux" ]; then
  shift
  case "${1:-}" in
    -h|--help)
      echo "usage: $_self mux [a|attach] [session-name]" >&2
      exit 0 ;;
    a|attach)
      shift ;;
  esac
  [ $# -le 1 ] || { echo "usage: $_self mux [a|attach] [session-name]" >&2; exit 2; }
  _mux_name="${1:-main}"
  if [ -z "${KILIX_IN_OVERLAY:-}" ] && [ -n "${KITTY_WINDOW_ID:-}" ] \
       && [ -n "${KITTY_LISTEN_ON:-}" ] && [ -x "$KITTEN" ]; then
    exec "$KITTEN" @ launch --type=tab --cwd=current --tab-title "mux:$_mux_name" \
      --env KILIX_IN_OVERLAY=1 --env KILIX_STREAM=1 -- "$_self" serve "$_mux_name"
  fi
  exec "$_self" serve "$_mux_name"
fi

# screensaver: a terminal screensaver in this pane (default: matrix). The
# screensavers are small self-contained C programs in config/screensavers/,
# compiled on first use and cached under .build/ (needs a C compiler, like the
# fork build). Usage: `kilix screensaver` or `kilix screensaver <name>`.
if [ "${1:-}" = "screensaver" ]; then
  shift
  # Host it in an overlay window (own title bar + close ✕) like browse/run, so
  # it can be dismissed with a click and reveals the shell underneath.
  if [ -z "${KILIX_IN_OVERLAY:-}" ] && [ -n "${KITTY_WINDOW_ID:-}" ] \
       && [ -n "${KITTY_LISTEN_ON:-}" ] && [ -x "$KITTEN" ]; then
    exec "$KITTEN" @ launch --type=overlay --cwd=current \
      --env KILIX_IN_OVERLAY=1 -- "$_self" screensaver "$@"
  fi
  _ss="${1:-matrix}"; [ $# -gt 0 ] && shift
  _sssrc="$KILIX_HOME/config/screensavers/$_ss.c"
  _sscache="${XDG_CACHE_HOME:-$HOME/.cache}/kilix/screensavers"
  _ssbin="$_sscache/$_ss"
  _sslegacy="$KILIX_HOME/config/screensavers/.build/$_ss"
  if [ -x "$_sslegacy" ] && [ ! -e "$_ssbin" ]; then
    mkdir -p "$_sscache"
    mv "$_sslegacy" "$_ssbin" 2>/dev/null \
      || cp "$_sslegacy" "$_ssbin" 2>/dev/null || true
  fi
  if [ ! -f "$_sssrc" ]; then
    echo "kilix: no screensaver '$_ss'. Available:" >&2
    for _f in "$KILIX_HOME"/config/screensavers/*.c; do
      [ -e "$_f" ] && echo "  $(basename "$_f" .c)" >&2
    done
    exit 1
  fi
  if [ ! -x "$_ssbin" ] || [ "$_sssrc" -nt "$_ssbin" ]; then     # (re)build if stale
    mkdir -p "$_sscache"
    cc -O2 -o "$_ssbin" "$_sssrc" || {
      echo "kilix: could not build screensaver '$_ss' (needs a C compiler)" >&2; exit 1; }
  fi
  exec "$_ssbin" "$@"
fi

# serve / attach / view — session persistence + multi-device attach (Phase 1
# "text plane"). A PRIVATE tmux server on a socket under the kilix runtime dir
# (never your ~/.tmux.conf) keeps a kilix session alive across disconnects and
# lets several devices attach at once: read-write (attach) or read-only (view).
# KILIX_STREAM=1 is set in the session so `kilix browse/run/icat` use inline
# (t=d) graphics that survive a remote attach. Reach it from another device over
# SSH, e.g.  ssh -t user@host ~/kilix/kilix attach
case "${1:-}" in
  serve|attach|view)
    command -v tmux >/dev/null 2>&1 || {
      echo "kilix $1: needs tmux (session multiplexing) — not found" >&2; exit 1; }
    _rundir="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}/kilix"
    if mkdir -p "$_rundir"; then chmod 700 "$_rundir" 2>/dev/null || true; fi
    _sock="$_rundir/tmux.sock"
    _tconf="$KILIX_HOME/config/tmux.conf"
    _sub="$1"; shift
    case "${1:-}" in
      ls|list|status)
        tmux -S "$_sock" list-sessions 2>/dev/null || echo "kilix: no sessions running"
        exit 0 ;;
      kill|clean)
        shift
        if [ -n "${1:-}" ]; then exec tmux -S "$_sock" kill-session -t "kilix-$1"; fi
        # no name: stop everything — text sessions AND any pixel-plane strays
        # (Xvnc/Xvfb/ffmpeg/bridge) left by a SIGKILLed serve.
        python3 -c "import sys;sys.path.insert(0,'$KILIX_HOME/config');import stream;print('kilix: reaped',stream.kill_all(),'stream processes')" 2>/dev/null || true
        if tmux -S "$_sock" kill-server 2>/dev/null; then
          echo "kilix: stopped tmux sessions"
        fi
        exit 0 ;;
    esac
    _name="${1:-main}"; _session="kilix-$_name"
    case "$_sub" in
      serve)
        _ushell="${SHELL:-$(getent passwd "$(id -un)" 2>/dev/null | cut -d: -f7)}"
        _ushell="${_ushell:-/bin/bash}"
        if [ -f "$KILIX_HOME/config/kilix.bashrc" ] && [ "${_ushell##*/}" = bash ]; then
          _shcmd="$_ushell --rcfile $KILIX_HOME/config/kilix.bashrc"
        else
          _shcmd="$_ushell"
        fi
        echo "kilix serve: session '$_session' (socket $_sock)"
        echo "  attach (read-write):  $_self attach $_name"
        echo "  view   (read-only) :  $_self view $_name"
        echo "  another device     :  ssh -t $(id -un)@$(hostname 2>/dev/null || echo HOST) $_self attach $_name"
        exec tmux -S "$_sock" -f "$_tconf" new-session -A -s "$_session" \
          -e KILIX_STREAM=1 -e "KILIX_HOME=$KILIX_HOME" \
          -e "KITTY_CONFIG_DIRECTORY=$KITTY_CONFIG_DIRECTORY" "$_shcmd" ;;
      attach) exec tmux -S "$_sock" attach-session -t "$_session" ;;
      view)   exec tmux -S "$_sock" attach-session -r -t "$_session" ;;
    esac ;;
esac

# icat inside a streamed session: force inline (stream) transmission + unicode
# placeholders so images survive a remote/tmux attach; locally, plain icat.
if [ "${1:-}" = icat ] && [ -x "$KITTEN" ]; then
  shift
  if [ "${KILIX_STREAM:-}" = 1 ]; then
    exec "$KITTEN" icat --transfer-mode=stream --unicode-placeholder "$@"
  fi
  exec "$KITTEN" icat "$@"
fi

# Kittens (kilix icat foo.png, kilix diff a b, …) run via the sibling kitten
# launcher, not by opening a new terminal window. The kitten list is probed
# from `kitten --help` so it tracks whatever the active binary ships; any
# non-kitten bare word still falls through to kitty (= run it in a window).
if [ $# -gt 0 ] && [ -x "$KITTEN" ]; then
  case "$1" in
    -*) ;;  # an option, not a kitten name
    *)
      if "$KITTEN" --help 2>/dev/null | sed -n '/^Commands:/,/^$/p' | grep -qFx "   $1"; then
        exec "$KITTEN" "$@"
      fi ;;
  esac
fi

# Carry prompt/shell tweaks in config/kilix.bashrc instead of ~/.bashrc, so
# they apply only to kilix sessions — not regular shells or tmux. bash only
# (the rcfile is bash); it sources ~/.bashrc, keeps kitty's shell integration
# working, then applies a kilix-only prompt. Delete config/kilix.bashrc to opt
# out. KILIX_HOME is exported so the rcfile can find its prompt override.
export KILIX_HOME
KILIX_SHELL=()
_ushell="${SHELL:-$(getent passwd "$(id -un)" 2>/dev/null | cut -d: -f7)}"
if [ "${KILIX_SHELL_INTEGRATION:-1}" != 0 ] \
     && [ -f "$KILIX_HOME/config/kilix.bashrc" ] && [ "${_ushell##*/}" = bash ]; then
  KILIX_SHELL=(-o "shell=$_ushell --rcfile $KILIX_HOME/config/kilix.bashrc")
fi

# --class kilix: own WM_CLASS/app_id so kilix groups separately from kitty
# in the taskbar and picks up the kilix icon via kilix.desktop.
exec "$BIN" --class kilix "${KILIX_SHELL[@]}" "$@"
