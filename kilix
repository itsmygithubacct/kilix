#!/usr/bin/env bash
# kilix — a Tilix-styled kitty with clickable pane-title-bar buttons.
#
# Runs the forked kitty built from ./src (the "clickable-chrome" fork: each pane
# title bar gets clickable [|] [-] [maximize] [x] buttons) with the
# kilix configuration (Tilix-like per-pane title bars, splits, keybindings,
# theming). Falls back to a prebuilt kitty in the Kilix storage directory if
# the fork is not built yet. Fully self-contained; any extra args are forwarded
# to kitty.
#
#   ./kilix                   # launch kilix
#   ./kilix ls [--panes]      # list live kilix pages/tabs or panes in this instance
#   ./kilix focus <id>        # focus a live tab/pane by ID
#   ./kilix watch <pane-id>   # best-effort read-only text watch of a live pane
#   ./kilix fullscreen        # toggle this tab's OS window fullscreen
#   ./kilix mux [name]        # open a tmux-backed kilix tab for real attach/view
#   ./kilix screen-size ...   # show/increase/decrease/reset terminal scale
#   ./kilix settings          # shared chrome/game settings TUI and CLI
#   ./kilix games ...         # list, enable, or disable Kilix 95 games
#   ./kilix temps [args]       # run the pinned graphical thermal dashboard
#   ./kilix memory [args]      # run the graphical RAM/pressure dashboard
#   ./kilix tmux [args]        # install/run the pinned Tmux Manager
#   ./kilix status            # show version, engine, config, and provider
#   ./kilix update            # verified-origin, clean, fast-forward/ref update
#   ./kilix desktop           # launch the configured desktop provider
#   ./kilix --build           # build the forked kitty from ./src
#   ./kilix --which           # print the kitty binary kilix uses + its version
#   ./kilix --install-desktop # desktop entry + icon (own taskbar group)
set -euo pipefail
umask 077

# Resolve symlinks so `ln -s .../kilix ~/.local/bin/kilix` still finds the project.
_self="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
KILIX_HOME="$(cd "$(dirname "$_self")" && pwd)"
GPU_TERMINAL_SOURCE_HOME="${GPU_TERMINAL_SOURCE_HOME:-$HOME/gpu_terminal}"
GPU_TERMINAL_HOME="${GPU_TERMINAL_HOME:-$HOME/.local/gpu_terminal}"
GPU_TERMINAL_SETTINGS_FILE="${GPU_TERMINAL_SETTINGS_FILE:-$GPU_TERMINAL_HOME/settings.conf}"
KILIX_STORAGE_HOME="${KILIX_STORAGE_HOME:-$GPU_TERMINAL_HOME/kilix}"
KILIX_CONFIG_HOME="${KILIX_CONFIG_HOME:-$KILIX_STORAGE_HOME/config}"
KILIX_STATE_DIRECTORY="${KILIX_STATE_DIRECTORY:-$KILIX_STORAGE_HOME/state}"
KILIX_CACHE_HOME="${KILIX_CACHE_HOME:-$KILIX_STORAGE_HOME/cache}"
KILIX_SESSION_HOME="${KILIX_SESSION_HOME:-$KILIX_STORAGE_HOME/session}"
KILIX_DATA_HOME="${KILIX_DATA_HOME:-$KILIX_STORAGE_HOME/data}"
KILIX_BUILD_DIRECTORY="${KILIX_BUILD_DIRECTORY:-$KILIX_STORAGE_HOME/build}"
KILIX_PREBUILT_HOME="${KILIX_PREBUILT_HOME:-$KILIX_STORAGE_HOME/prebuilt/kitty.app}"
KILIX95_STORAGE_HOME="${KILIX95_STORAGE_HOME:-$GPU_TERMINAL_HOME/kilix-95}"
KILIX95_CONFIG_HOME="${KILIX95_CONFIG_HOME:-$KILIX95_STORAGE_HOME/config}"
KILIX95_STATE_HOME="${KILIX95_STATE_HOME:-$KILIX95_STORAGE_HOME/state}"
KILIX95_CACHE_HOME="${KILIX95_CACHE_HOME:-$KILIX95_STORAGE_HOME/cache}"
KILIX95_SESSION_HOME="${KILIX95_SESSION_HOME:-$KILIX95_STORAGE_HOME/session}"
KILIX95_DATA_HOME="${KILIX95_DATA_HOME:-$KILIX95_STORAGE_HOME/data}"
export GPU_TERMINAL_SOURCE_HOME GPU_TERMINAL_HOME GPU_TERMINAL_SETTINGS_FILE
export KILIX_STORAGE_HOME KILIX_CONFIG_HOME
export KILIX_STATE_DIRECTORY KILIX_CACHE_HOME KILIX_SESSION_HOME KILIX_DATA_HOME
export KILIX_BUILD_DIRECTORY KILIX_PREBUILT_HOME
export KILIX95_STORAGE_HOME KILIX95_CONFIG_HOME KILIX95_STATE_HOME
export KILIX95_CACHE_HOME KILIX95_SESSION_HOME KILIX95_DATA_HOME

_kilix_validate_private_storage_layout() {
  local storage private home source
  storage="$(realpath -m -- "$KILIX_STORAGE_HOME" 2>/dev/null)" || return 1
  home="$(realpath -m -- "$HOME" 2>/dev/null)" || return 1
  source="$(realpath -m -- "$KILIX_HOME" 2>/dev/null)" || return 1
  if [ "$storage" = / ] || [ "$storage" = "$home" ] \
       || [ "$storage" = "$source" ]; then
    echo "kilix: refusing broad or source-tree storage root: $storage" >&2
    return 1
  fi
  case "$storage" in "$source"/*)
    echo "kilix: refusing storage inside the Kilix source checkout" >&2
    return 1 ;;
  esac
  case "$source" in "$storage"/*)
    echo "kilix: refusing storage that contains the Kilix source checkout" >&2
    return 1 ;;
  esac
  for private in "$KILIX_CONFIG_HOME" "$KILIX_STATE_DIRECTORY" \
                 "$KILIX_CACHE_HOME" "$KILIX_SESSION_HOME" \
                 "$KILIX_DATA_HOME" "$KILIX_BUILD_DIRECTORY"; do
    private="$(realpath -m -- "$private" 2>/dev/null)" || return 1
    case "$private" in "$storage"/*) ;;
      *) echo "kilix: writable roots must be strict descendants of Kilix storage: $private" >&2
         return 1 ;;
    esac
  done
}

_kilix_ensure_private_directory() {
  local path="$1" label="$2" owner mode
  if [ -e "$path" ] || [ -L "$path" ]; then
    if [ ! -d "$path" ] || [ -L "$path" ]; then
      echo "kilix: refusing unsafe $label directory: $path" >&2
      return 1
    fi
  else
    mkdir -p -- "$path" || return 1
  fi
  owner="$(stat -c '%u' -- "$path" 2>/dev/null)" || return 1
  [ "$owner" = "$(id -u)" ] || {
    echo "kilix: $label directory is not owned by the current user: $path" >&2
    return 1
  }
  chmod 0700 -- "$path" || return 1
  mode="$(stat -c '%a' -- "$path" 2>/dev/null)" || return 1
  [ "$mode" = 700 ] || {
    echo "kilix: $label directory is not mode 0700: $path" >&2
    return 1
  }
}

_kilix_validate_private_storage_layout || exit 1
_kilix_ensure_private_directory "$KILIX_STORAGE_HOME" storage || exit 1
_kilix_ensure_private_directory "$KILIX_STATE_DIRECTORY" state || exit 1
_kilix_ensure_private_directory "$KILIX_BUILD_DIRECTORY" build || exit 1
_kilix_ensure_private_directory "$KILIX_CACHE_HOME" cache || exit 1
_kilix_ensure_private_directory "$KILIX_SESSION_HOME" session || exit 1
_kilix_validate_private_storage_layout || exit 1

FORK="$KILIX_BUILD_DIRECTORY/current/src/kitty/launcher/kitty"
PREBUILT="$KILIX_PREBUILT_HOME/bin/kitty"

# A fresh install owns this complete tree. Legacy XDG/source-tree locations are
# deliberately never moved: provider storage is isolated and launch is free of
# cross-project data mutations.
export KITTY_CACHE_DIRECTORY="${KITTY_CACHE_DIRECTORY:-$KILIX_CACHE_HOME/kitty}"
export KITTY_RUNTIME_DIRECTORY="${KITTY_RUNTIME_DIRECTORY:-$KILIX_SESSION_HOME/kitty}"
# Tracked files under ./config are immutable defaults.  Normal runtime changes
# live under the Kilix storage root so Settings/screen-size never dirty the checkout.
# The generated user kitty.conf includes the tracked default file, which means
# new defaults arrive on update without overwriting user overrides.  The
# KILIX_CONFIG_DIRECTORY override remains available for tests/custom packaging.
KILIX_DEFAULT_CONFIG_DIRECTORY="$KILIX_HOME/config"
KILIX_USER_CONFIG_DIRECTORY="$KILIX_CONFIG_HOME"
_KILIX_DEFAULTS_LINK="$KILIX_USER_CONFIG_DIRECTORY/.kilix-defaults.conf"
_KILIX_CONFIG_MARKER="# Kilix user overrides. Tracked defaults are loaded first."

_kilix_refresh_managed_link() {
  _target="$1" _source="$2"
  if [ -L "$_target" ]; then
    ln -sfn "$_source" "$_target"
  elif [ ! -e "$_target" ]; then
    ln -s "$_source" "$_target"
  fi
}

_kilix_refresh_generated_include() {
  _target="$1"
  [ -f "$_target" ] || return 0
  grep -qF "$_KILIX_CONFIG_MARKER" "$_target" 2>/dev/null || return 0
  _tmp="$(mktemp "${_target}.tmp.XXXXXX")"
  awk -v marker="$_KILIX_CONFIG_MARKER" '
    $0 == marker { managed=1; print; next }
    managed && !done && /^include / {
      print "include .kilix-defaults.conf"; done=1; next
    }
    { print }
    END { if (!done) print "include .kilix-defaults.conf" }
  ' "$_target" >"$_tmp"
  mv "$_tmp" "$_target"
}

_kilix_init_user_config() {
  _kilix_ensure_private_directory "$KILIX_USER_CONFIG_DIRECTORY" config || return 1
  _user_kitty="$KILIX_USER_CONFIG_DIRECTORY/kitty.conf"
  _user_env="$KILIX_USER_CONFIG_DIRECTORY/kilix.env"

  _kilix_refresh_managed_link "$_KILIX_DEFAULTS_LINK" \
    "$KILIX_DEFAULT_CONFIG_DIRECTORY/kitty.conf"

  if [ ! -e "$_user_kitty" ]; then
    printf '%s\n%s\n' "$_KILIX_CONFIG_MARKER" \
      'include .kilix-defaults.conf' >"$_user_kitty"
  fi
  _kilix_refresh_generated_include "$_user_kitty"
  if [ ! -e "$_user_env" ]; then
    printf '%s\n' '# Kilix user runtime overrides (KEY=value; not shell code).' >"$_user_env"
  fi
  chmod 600 "$_user_kitty" "$_user_env" 2>/dev/null || true

  # Refresh managed symlinks on every launch so moving/reinstalling the checkout
  # does not strand the XDG configuration at an obsolete absolute path.
  for _asset in kitty.app.png kitty.app-128.png kilix-512.png kilix_rc_auth.py; do
    _kilix_refresh_managed_link "$KILIX_USER_CONFIG_DIRECTORY/$_asset" \
      "$KILIX_DEFAULT_CONFIG_DIRECTORY/$_asset" 2>/dev/null || true
  done
}

_kilix_init_rc_password() {
  local password_file="$KILIX_SESSION_HOME/rc-password"
  local config_file="$KILIX_SESSION_HOME/rc-password.conf"
  local tmp password metadata
  if [ ! -e "$password_file" ] && [ ! -L "$password_file" ]; then
    tmp="$(mktemp "$KILIX_SESSION_HOME/.rc-password.XXXXXX")" || return 1
    password="$(od -An -N32 -tx1 /dev/urandom | tr -d ' \n')"
    if [[ ! "$password" =~ ^[0-9a-f]{64}$ ]]; then
      rm -f -- "$tmp"
      echo "kilix: could not generate a remote-control password" >&2
      return 1
    fi
    printf '%s\n' "$password" >"$tmp"
    chmod 0600 "$tmp" || { rm -f -- "$tmp"; return 1; }
    ln "$tmp" "$password_file" 2>/dev/null || true
    rm -f -- "$tmp"
  fi
  if [ ! -f "$password_file" ] || [ -L "$password_file" ]; then
    echo "kilix: refusing unsafe remote-control password file" >&2
    return 1
  fi
  metadata="$(stat -c '%u:%a:%h' -- "$password_file" 2>/dev/null)" || return 1
  if [ "$metadata" != "$(id -u):600:1" ]; then
    echo "kilix: remote-control password file must be private" >&2
    return 1
  fi
  password="$(tr -d '\n' <"$password_file")"
  if [[ ! "$password" =~ ^[0-9a-f]{64}$ ]]; then
    echo "kilix: remote-control password file is invalid" >&2
    return 1
  fi
  tmp="$(mktemp "$KILIX_SESSION_HOME/.rc-config.XXXXXX")" || return 1
  printf 'remote_control_password "%s" launch ls focus-window focus-tab get-text\n' \
    "$password" >"$tmp"
  chmod 0600 "$tmp" || { rm -f -- "$tmp"; return 1; }
  mv -f -- "$tmp" "$config_file"
  KILIX_RC_PASSWORD_FILE="$password_file"
  KILIX_RC_CONFIG_FILE="$config_file"
  export KILIX_RC_PASSWORD_FILE KILIX_RC_CONFIG_FILE
}

if [ -n "${KILIX_CONFIG_DIRECTORY:-}" ]; then
  export KITTY_CONFIG_DIRECTORY="$KILIX_CONFIG_DIRECTORY"
else
  _kilix_init_user_config
  export KITTY_CONFIG_DIRECTORY="$KILIX_USER_CONFIG_DIRECTORY"
fi
_kilix_init_rc_password || exit 1
export KILIX_ENV_CONFIG="${KILIX_ENV_CONFIG:-$KITTY_CONFIG_DIRECTORY/kilix.env}"

declare -A _KILIX_ENV_SEEN=()
declare -A _KILIX_ENV_EXPLICIT=()
_kilix_load_env_file() {
  _conf="$1"
  [ -f "$_conf" ] || return 0
  while IFS= read -r _line || [ -n "$_line" ]; do
    _line="${_line%$'\r'}"
    case "$_line" in ''|\#*) continue ;; esac
    case "$_line" in *=*) ;; *) continue ;; esac
    _key="${_line%%=*}"
    _val="${_line#*=}"
    case "$_key" in
      KILIX_CHROME_CLOCK|KILIX_CHROME_CLOCK_FORMAT|KILIX_CHROME_BATTERY|KILIX_BATTERY_SUPPLY_DIR|\
      KILIX_DESKTOP_PROVIDER|KILIX_DESKTOP_COMMAND|KILIX_DESKTOP_NAME|KILIX_DESKTOP_FLAVOR|KILIX_DESKTOP_DIR|\
      KILIX95_AUTO_INSTALL|KILIX95_DIR|KILIX95_REPO|KILIX95_BRANCH|KILIX95_REF|KILIX95_TRUST_EXISTING_CHECKOUT|\
      KILIX95_ALLOW_MUTABLE_REF|KILIX95_ALLOW_UNPINNED_INSTALL|\
      KILIX_RECYCLE_DIR|KILIX_SAVER_IDLE|KILIX_HOST_CLIP|KILIX_NO_SOUND|KILIX_XPANE_WM|\
      KILIX_RUN_AUTO_FIT|KILIX_NO_PANE|KILIX_DEBUG|KILIX_HW|KILIX_BROWSE_BACKEND|KILIX_BROWSE_LOG|KILIX_RUN_LOG|\
      KILIX_XFONTS|KILIX_BRIDGE_TOKEN|KILIX_SHELL_INTEGRATION|\
      KILIX_REF|KILIX_REPO|KILIX_TRUST_EXISTING_CHECKOUT|KILIX_ALLOW_MUTABLE_REF|\
      KILIX_PREBUILT_VERSION|KILIX_PREBUILT_SHA256|KILIX_ALLOW_UNVERIFIED_PREBUILT|\
      KILIX_BUILD_MODE|KILIX_KITTY_DEPS_URL|KILIX_KITTY_DEPS_SHA256|\
      KILIX_TEMPS_REPO|KILIX_TEMPS_REF|KILIX_TEMPS_PREFIX|\
      KILIX_TEMPS_PRESENTER_REPO|KILIX_TEMPS_PRESENTER_REF|\
      KILIX_TEMPS_SOFT_RASTER_PY_REPO|KILIX_TEMPS_SOFT_RASTER_PY_REF|\
      KILIX_TEMPS_SOFT_RASTER_REPO|KILIX_TEMPS_SOFT_RASTER_REF|\
      KILIX_MEMORY_REPO|KILIX_MEMORY_REF|KILIX_MEMORY_PREFIX|\
      KILIX_MEMORY_PRESENTER_REPO|KILIX_MEMORY_PRESENTER_REF|\
      KILIX_MEMORY_SOFT_RASTER_PY_REPO|KILIX_MEMORY_SOFT_RASTER_PY_REF|\
      KILIX_MEMORY_SOFT_RASTER_REPO|KILIX_MEMORY_SOFT_RASTER_REF|\
      TMUX_TUI_REPO|TMUX_TUI_REF|TMUX_CLI_REF|TMUX_TUI_PREFIX|\
      KILIX_NERD_FONT_URL|KILIX_NERD_FONT_SHA256|KILIX_NERD_FONT_FILE_SHA256|KILIX_GO_TOOLCHAIN|KILIX_PYTHON)
        # An explicit process environment wins over persisted settings. Storage
        # roots are intentionally absent from this allowlist: they determine
        # where this file is found and must be supplied by the launcher/service.
        if [[ ! ${_KILIX_ENV_SEEN[$_key]+yes} ]]; then
          _KILIX_ENV_SEEN["$_key"]=1
          [[ ! -v $_key ]] || _KILIX_ENV_EXPLICIT["$_key"]=1
        fi
        if [[ ! ${_KILIX_ENV_EXPLICIT[$_key]+yes} ]]; then
          export "$_key=$_val"
        fi ;;
    esac
  done < "$_conf"
}
_kilix_load_env_file "$KILIX_DEFAULT_CONFIG_DIRECTORY/kilix.env"
[ "$KILIX_ENV_CONFIG" = "$KILIX_DEFAULT_CONFIG_DIRECTORY/kilix.env" ] \
  || _kilix_load_env_file "$KILIX_ENV_CONFIG"

# One non-executable KEY=value file at the common GPU Terminal root is the
# source of truth for status widgets, pane-title controls, and Kilix 95 game
# availability. The first creation migrates the two legacy kilix.env toggles.
if ! python3 "$KILIX_HOME/kilix-settings" --ensure; then
  echo "kilix: could not initialize shared settings: $GPU_TERMINAL_SETTINGS_FILE" >&2
  exit 1
fi

# Source checkouts are siblings under ~/gpu_terminal by default. Resolve this
# only after loading user runtime settings so KILIX95_DIR remains configurable,
# while every writable provider root stays independently anchored above.
KILIX95_DIR="${KILIX95_DIR:-$GPU_TERMINAL_SOURCE_HOME/kilix-95}"
export KILIX95_DIR

# No-sudo streaming deps (Xvfb / Xvnc / vncpasswd / python-xlib unpacked by
# scripts/install-stream-deps.sh on hosts that lack them): pull in their
# PATH / LD_LIBRARY_PATH / PYTHONPATH so the serve modes find them. A no-op
# where the deps are already system-installed (the file won't exist).
_kx_env="$KILIX_DATA_HOME/stream-env.sh"
if [ -f "$_kx_env" ]; then
  # shellcheck disable=SC1090
  . "$_kx_env"
fi

case "${1:-}" in
  # build.sh is invoked from the checkout root everywhere: it is cwd-independent
  # today, but running it from the caller's directory would let any future
  # cwd-relative path in it touch an unrelated tree.
  --build) shift; cd "$KILIX_HOME"; exec "$KILIX_HOME/build.sh" "$@" ;;
  --kilix-version|kilix-version)
    # The Plebian-OS release version of this kilix checkout. (Plain `--version`
    # is passed through to the kitty engine by --which/exec, so this is a
    # distinct flag for the launcher's own version.)
    cat "$KILIX_HOME/VERSION" 2>/dev/null || echo unknown
    exit 0 ;;
  settings|--settings)
    shift
    exec python3 "$KILIX_HOME/kilix-settings" "$@" ;;
  games|--games)
    shift
    _games_action="${1:-list}"
    [ $# -eq 0 ] || shift
    case "$_games_action" in
      list)
        [ $# -eq 0 ] || {
          echo "usage: $_self games [list|settings|enable GAME...|disable GAME...]" >&2
          exit 2
        }
        exec python3 "$KILIX_HOME/kilix-settings" --print-games ;;
      settings|configure)
        [ $# -eq 0 ] || {
          echo "usage: $_self games settings" >&2
          exit 2
        }
        exec python3 "$KILIX_HOME/kilix-settings" --section games ;;
      enable|disable)
        [ $# -gt 0 ] || {
          echo "usage: $_self games $_games_action GAME..." >&2
          exit 2
        }
        _games_state=on
        [ "$_games_action" = enable ] || _games_state=off
        _games_args=()
        for _game in "$@"; do
          _games_args+=(--game "$_game=$_games_state")
        done
        exec python3 "$KILIX_HOME/kilix-settings" \
          "${_games_args[@]}" --print-games ;;
      -h|--help|help)
        echo "usage: $_self games [list|settings|enable GAME...|disable GAME...]"
        exit 0 ;;
      *)
        echo "usage: $_self games [list|settings|enable GAME...|disable GAME...]" >&2
        exit 2 ;;
    esac ;;
  temps|temperature|temperatures)
    shift
    _temps_install_only=0
    _temps_force=0
    while :; do
      case "${1:-}" in
        --install-only) _temps_install_only=1; shift ;;
        --force-install) _temps_force=1; shift ;;
        *) break ;;
      esac
    done
    _temps_installed="${KILIX_TEMPS_PREFIX:-$HOME/.local}/bin/kilix-temps"
    if [ "$_temps_force" = 1 ]; then
      "$KILIX_HOME/scripts/install-kilix-temps.sh" --force
    else
      "$KILIX_HOME/scripts/install-kilix-temps.sh"
    fi
    [ -x "$_temps_installed" ] \
      || { echo "kilix temps: installer did not create $_temps_installed" >&2; exit 1; }
    [ "$_temps_install_only" = 0 ] || exit 0
    exec "$_temps_installed" "$@" ;;
  memory|mem|ram)
    shift
    _memory_install_only=0
    _memory_force=0
    while :; do
      case "${1:-}" in
        --install-only) _memory_install_only=1; shift ;;
        --force-install) _memory_force=1; shift ;;
        *) break ;;
      esac
    done
    _memory_installed="${KILIX_MEMORY_PREFIX:-$HOME/.local}/bin/kilix-memory"
    if [ "$_memory_force" = 1 ]; then
      "$KILIX_HOME/scripts/install-kilix-memory.sh" --force
    else
      "$KILIX_HOME/scripts/install-kilix-memory.sh"
    fi
    [ -x "$_memory_installed" ] \
      || { echo "kilix memory: installer did not create $_memory_installed" >&2; exit 1; }
    [ "$_memory_install_only" = 0 ] || exit 0
    exec "$_memory_installed" "$@" ;;
  tmux|tmux-manager|tmux-tui)
    shift
    _tmux_install_only=0
    _tmux_force=0
    _tmux_tb_mode=
    while :; do
      case "${1:-}" in
        --install-only) _tmux_install_only=1; shift ;;
        --force-install) _tmux_force=1; shift ;;
        --with-tb) _tmux_tb_mode=--with-tb; shift ;;
        --without-tb) _tmux_tb_mode=--without-tb; shift ;;
        --) shift; break ;;
        *) break ;;
      esac
    done
    _tmux_installer=("$KILIX_HOME/scripts/install-tmux-tui.sh")
    [ "$_tmux_force" = 0 ] || _tmux_installer+=(--force)
    [ -z "$_tmux_tb_mode" ] || _tmux_installer+=("$_tmux_tb_mode")
    "${_tmux_installer[@]}"
    _tmux_installed="${TMUX_TUI_PREFIX:-$HOME/.local}/bin/tmux-tui"
    [ -x "$_tmux_installed" ] \
      || { echo "kilix tmux: installer did not create $_tmux_installed" >&2; exit 1; }
    [ "$_tmux_install_only" = 0 ] || exit 0
    exec "$_tmux_installed" "$@" ;;
  status|--status)
    _status_version="$(cat "$KILIX_HOME/VERSION" 2>/dev/null || echo unknown)"
    _status_head="$(git -C "$KILIX_HOME" rev-parse --short HEAD 2>/dev/null || echo not-a-checkout)"
    _status_dirty=clean
    git -C "$KILIX_HOME" diff --quiet --ignore-submodules=none HEAD -- 2>/dev/null \
      || _status_dirty=modified
    if [ -x "$FORK" ]; then _status_engine="$FORK"
    elif [ -x "$PREBUILT" ]; then _status_engine="$PREBUILT"
    else _status_engine=missing
    fi
    _status_provider="${KILIX_DESKTOP_PROVIDER:-auto}"
    _status_provider_dir="$KILIX95_DIR"
    case "$_status_provider" in
      auto)
        if [ -f "$_status_provider_dir/main.py" ]; then
          _status_provider="external (authoritative)"
        else
          _status_provider="builtin (compatibility fallback; external absent)"
          _status_provider_dir="$KILIX_HOME/desktop"
        fi ;;
      builtin)
        _status_provider_dir="$KILIX_HOME/desktop"
        ;;
      command|custom|none|off|disabled)
        _status_provider_dir=""
        ;;
    esac
    printf '%s\n' \
      "kilix $_status_version ($_status_head, $_status_dirty)" \
      "engine: $_status_engine" \
      "config: $KITTY_CONFIG_DIRECTORY/kitty.conf" \
      "runtime config: $KILIX_ENV_CONFIG" \
      "shared settings: $GPU_TERMINAL_SETTINGS_FILE" \
      "desktop provider: $_status_provider" \
      "desktop path: ${_status_provider_dir:-n/a}"
    if [ -n "$_status_provider_dir" ] && [ -f "$_status_provider_dir/main.py" ]; then
      python3 "$KILIX_HOME/scripts/check-desktop-provider.py" \
        "$_status_provider_dir" || exit $?
    fi
    exit 0 ;;
  update|--update)
    # Update only from the expected origin, only from a clean checkout, and
    # only by an explicit origin fast-forward or detached ref checkout.
    _kilix_acquire_transaction_lock() {
      local lock_root lock_path fd fd_path path_identity fd_identity lock_was_present=0
      if ! command -v flock >/dev/null 2>&1; then
        echo "kilix update: flock not found" >&2
        return 1
      fi
      _kilix_ensure_private_directory "$KILIX_STATE_DIRECTORY" state || return 1
      lock_root="$(cd "$KILIX_STATE_DIRECTORY" && pwd -P)" || return 1
      lock_path="$lock_root/build-update.lock"
      if [ -e "$lock_path" ] || [ -L "$lock_path" ]; then
        lock_was_present=1
        if [ ! -f "$lock_path" ] || [ -L "$lock_path" ]; then
          echo "kilix update: refusing unsafe transaction lock: $lock_path" >&2
          return 1
        fi
        if [ "$(stat -c '%u:%a:%h' -- "$lock_path" 2>/dev/null)" \
             != "$(id -u):600:1" ]; then
          echo "kilix update: transaction lock is not a private regular file" >&2
          return 1
        fi
      fi
      if [ -n "${KILIX_TRANSACTION_LOCK_FD:-}" ]; then
        fd="$KILIX_TRANSACTION_LOCK_FD"
        case "$fd" in ''|*[!0-9]*)
          echo "kilix update: invalid inherited KILIX_TRANSACTION_LOCK_FD" >&2
          return 1 ;;
        esac
        fd_path="/proc/$$/fd/$fd"
        [ -e "$fd_path" ] || {
          echo "kilix update: inherited transaction-lock FD is not open" >&2
          return 1
        }
        [ "$lock_was_present" = 1 ] || {
          echo "kilix update: canonical transaction lock does not exist" >&2
          return 1
        }
      else
        exec {_kilix_transaction_lock_fd}>"$lock_path" || return 1
        fd="$_kilix_transaction_lock_fd"
        KILIX_TRANSACTION_LOCK_FD="$fd"
        export KILIX_TRANSACTION_LOCK_FD
        fd_path="/proc/$$/fd/$fd"
      fi
      [ "$lock_was_present" = 1 ] || chmod 0600 "$lock_path" 2>/dev/null || return 1
      if [ ! -f "$lock_path" ] || [ -L "$lock_path" ] \
           || [ "$(stat -c '%u:%a:%h' -- "$lock_path" 2>/dev/null)" \
                != "$(id -u):600:1" ]; then
        echo "kilix update: transaction lock is not a private regular file" >&2
        return 1
      fi
      path_identity="$(stat -c '%d:%i' -- "$lock_path" 2>/dev/null)" || return 1
      fd_identity="$(stat -Lc '%d:%i' -- "$fd_path" 2>/dev/null)" || return 1
      if [ "$fd_identity" != "$path_identity" ]; then
        echo "kilix update: inherited transaction-lock FD points to the wrong file" >&2
        return 1
      fi
      flock -x "$fd" || return 1
      KILIX_TRANSACTION_LOCK_PATH="$lock_path"
      export KILIX_TRANSACTION_LOCK_PATH
    }

    _kilix_acquire_transaction_lock || exit 1
    if ! command -v timeout >/dev/null 2>&1; then
      echo "kilix update: timeout not found" >&2
      exit 1
    fi
    if ! command -v git >/dev/null 2>&1; then
      echo "kilix update: git not found" >&2; exit 1
    fi
    if [ ! -d "$KILIX_HOME/.git" ]; then
      echo "kilix update: $KILIX_HOME is not a git checkout — nothing to pull" >&2
      exit 1
    fi
    _expected_origin="${KILIX_REPO:-https://github.com/itsmygithubacct/kilix.git}"
    _actual_origin="$(git -C "$KILIX_HOME" config --get remote.origin.url 2>/dev/null || true)"
    if [ -z "$_actual_origin" ]; then
      echo "kilix update: checkout has no origin remote" >&2; exit 1
    fi
    if [ "$_actual_origin" != "$_expected_origin" ] \
         && [ "${KILIX_TRUST_EXISTING_CHECKOUT:-0}" != 1 ]; then
      echo "kilix update: origin is '$_actual_origin', expected '$_expected_origin'" >&2
      echo "kilix update: set KILIX_TRUST_EXISTING_CHECKOUT=1 only if you trust it" >&2
      exit 1
    fi
    if [ -n "$(git -C "$KILIX_HOME" status --porcelain --untracked-files=normal 2>/dev/null)" ]; then
      echo "kilix update: refusing to overwrite a modified checkout" >&2
      echo "kilix update: user settings belong in $KILIX_USER_CONFIG_DIRECTORY" >&2
      exit 1
    fi

    _fork_stamp="$KILIX_STATE_DIRECTORY/fork-built-ref"
    _fork_current="$KILIX_BUILD_DIRECTORY/current"
    _fork_previous="$KILIX_BUILD_DIRECTORY/previous"
    _fork_source_id="$_fork_current/source-id"
    _fork_kitten="$(dirname "$FORK")/kitten"
    _update_active=0
    _update_committed=0
    _update_sources_mutated=0
    _engine_txn_active=0
    _update_txn_dir=""

    _kilix_entry_exists() {
      [ -e "$1" ] || [ -L "$1" ]
    }

    _kilix_assert_safe_fork_stamp() {
      local owner mode links
      _kilix_entry_exists "$_fork_stamp" || return 0
      if [ ! -f "$_fork_stamp" ] || [ -L "$_fork_stamp" ]; then
        echo "kilix update: refusing unsafe fork-build stamp: $_fork_stamp" >&2
        return 1
      fi
      owner="$(stat -c '%u' -- "$_fork_stamp" 2>/dev/null)" || return 1
      mode="$(stat -c '%a' -- "$_fork_stamp" 2>/dev/null)" || return 1
      links="$(stat -c '%h' -- "$_fork_stamp" 2>/dev/null)" || return 1
      if [ "$owner" != "$(id -u)" ] || [ "$mode" != 600 ] || [ "$links" != 1 ]; then
        echo "kilix update: fork-build stamp must be current-user-owned, mode 0600, and singly linked" >&2
        return 1
      fi
    }

    _kilix_generation_target_syntax_is_safe() {
      local target="$1" suffix
      case "$target" in generations/build.*) ;; *) return 1 ;; esac
      suffix="${target#generations/build.}"
      case "$suffix" in ''|*[!A-Za-z0-9]*) return 1 ;; esac
    }

    _kilix_generation_target_is_canonical() {
      local target="$1" suffix candidate build_root candidate_root
      _kilix_generation_target_syntax_is_safe "$target" || return 1
      suffix="${target#generations/build.}"
      candidate="$KILIX_BUILD_DIRECTORY/$target"
      [ -d "$candidate" ] && [ ! -L "$candidate" ] || return 1
      build_root="$(cd "$KILIX_BUILD_DIRECTORY" && pwd -P)" || return 1
      candidate_root="$(cd "$candidate" && pwd -P)" || return 1
      [ "$candidate_root" = "$build_root/generations/build.$suffix" ]
    }

    _kilix_has_fork_footprint() {
      _kilix_entry_exists "$_fork_current" || _kilix_entry_exists "$_fork_stamp"
    }

    _kilix_probe_launcher() {
      timeout --kill-after=2 15 "$1" --version >/dev/null 2>&1
    }

    _kilix_which_output() {
      timeout --kill-after=2 15 "$KILIX_HOME/kilix" --which 2>/dev/null
    }

    _fork_invalid_reason=""
    _kilix_fork_is_coherent() {
      local target root head which_output engine
      [ -L "$_fork_current" ] || {
        _fork_invalid_reason="current is not a generation symlink"; return 1
      }
      target="$(readlink -- "$_fork_current")" || {
        _fork_invalid_reason="could not read current generation link"; return 1
      }
      _kilix_generation_target_is_canonical "$target" || {
        _fork_invalid_reason="current generation link is not canonical and contained"; return 1
      }
      if [ ! -f "$FORK" ] || [ -L "$FORK" ] || [ ! -x "$FORK" ]; then
        _fork_invalid_reason="missing or unsafe fork engine: $FORK"; return 1
      fi
      if [ ! -f "$_fork_kitten" ] || [ -L "$_fork_kitten" ] \
           || [ ! -x "$_fork_kitten" ]; then
        _fork_invalid_reason="missing or unsafe kitten launcher: $_fork_kitten"; return 1
      fi
      if [ ! -f "$_fork_source_id" ] || [ -L "$_fork_source_id" ]; then
        _fork_invalid_reason="missing or unsafe source-id: $_fork_source_id"; return 1
      fi
      root="$(cd "$KILIX_HOME" && pwd -P)" || {
        _fork_invalid_reason="could not resolve the physical Kilix checkout"; return 1
      }
      head="$(git -C "$KILIX_HOME/src" rev-parse --verify HEAD 2>/dev/null)" || {
        _fork_invalid_reason="Kilix source checkout has no commit"; return 1
      }
      printf '%s\n' "$head" | cmp -s - "$_fork_source_id" || {
        _fork_invalid_reason="fork source-id does not exactly match the source checkout"; return 1
      }
      _kilix_assert_safe_fork_stamp || {
        _fork_invalid_reason="unsafe canonical fork-build stamp"; return 1
      }
      printf '%s\t%s\n' "$root" "$head" | cmp -s - "$_fork_stamp" || {
        _fork_invalid_reason="fork-build stamp does not exactly match the source checkout"; return 1
      }
      _kilix_probe_launcher "$_fork_kitten" || {
        _fork_invalid_reason="kitten failed its version probe"; return 1
      }
      which_output="$(_kilix_which_output)" || {
        _fork_invalid_reason="fork engine failed its version probe"; return 1
      }
      engine="${which_output%%$'\n'*}"
      [ "$engine" = "$FORK" ] || {
        _fork_invalid_reason="kilix --which selected ${engine:-<nothing>} instead of $FORK"; return 1
      }
    }

    _kilix_write_entry_identity() {
      local path="$1" output="$2"
      if _kilix_entry_exists "$path"; then
        stat -c '%F\t%d:%i' -- "$path" >"$output" || return 1
      else
        printf 'absent\n' >"$output" || return 1
      fi
    }

    _kilix_gc_generation_for_entry() {
      local entry="$1" target ref candidate build_root candidate_root
      [ -L "$entry" ] || return 0
      target="$(readlink -- "$entry")" || return 0
      _kilix_generation_target_syntax_is_safe "$target" || return 0
      for ref in "$_fork_current" "$_fork_previous" "$KILIX_BUILD_DIRECTORY/prepared"; do
        if [ -L "$ref" ] && [ "$(readlink -- "$ref" 2>/dev/null || true)" = "$target" ]; then
          return 0
        fi
      done
      candidate="$KILIX_BUILD_DIRECTORY/$target"
      [ -d "$candidate" ] && [ ! -L "$candidate" ] || return 0
      build_root="$(cd "$KILIX_BUILD_DIRECTORY" && pwd -P)" || return 0
      candidate_root="$(cd "$candidate" && pwd -P)" || return 0
      [ "$candidate_root" = "$build_root/$target" ] || return 0
      rm -rf -- "$candidate" || return 1
    }

    _before="$(git -C "$KILIX_HOME" rev-parse HEAD 2>/dev/null || echo unknown)"
    _before_branch="$(git -C "$KILIX_HOME" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
    _kilix_rollback_sources() {
      [ "$_update_sources_mutated" = 1 ] || return 0
      if [ -n "$_before_branch" ]; then
        if git -C "$KILIX_HOME" symbolic-ref --quiet HEAD >/dev/null 2>&1; then
          git -C "$KILIX_HOME" reset --keep "$_before" || return 1
        else
          git -C "$KILIX_HOME" checkout "$_before_branch" || return 1
        fi
      else
        git -C "$KILIX_HOME" checkout --detach "$_before" || return 1
      fi
      git -C "$KILIX_HOME" submodule update --init --recursive || return 1
    }

    _kilix_prepare_engine_transaction() {
      local stale
      _kilix_assert_safe_fork_stamp || return 1
      _kilix_ensure_private_directory "$KILIX_BUILD_DIRECTORY" build || return 1
      for stale in "$KILIX_BUILD_DIRECTORY"/.update-rollback.*; do
        _kilix_entry_exists "$stale" || continue
        echo "kilix update: recovery transaction already exists: $stale" >&2
        return 1
      done
      _update_txn_dir="$(mktemp -d "$KILIX_BUILD_DIRECTORY/.update-rollback.XXXXXX")" || return 1
      if ! chmod 0700 "$_update_txn_dir" \
           || ! _kilix_write_entry_identity "$_fork_current" "$_update_txn_dir/current.identity" \
           || ! _kilix_write_entry_identity "$_fork_previous" "$_update_txn_dir/previous.identity"; then
        rm -rf -- "$_update_txn_dir"
        _update_txn_dir=""
        return 1
      fi
      if _kilix_entry_exists "$_fork_stamp"; then
        if ! cp -a --no-dereference -- "$_fork_stamp" "$_update_txn_dir/fork-stamp" \
             || ! : >"$_update_txn_dir/fork-stamp.present"; then
          rm -rf -- "$_update_txn_dir"
          _update_txn_dir=""
          return 1
        fi
      fi
      _engine_txn_active=1
      if _kilix_entry_exists "$_fork_previous"; then
        mv -- "$_fork_previous" "$_update_txn_dir/previous.entry" || return 1
      fi
    }

    _kilix_restore_current() {
      _kilix_write_entry_identity "$_fork_current" "$_update_txn_dir/current.after" || return 1
      cmp -s "$_update_txn_dir/current.identity" "$_update_txn_dir/current.after" && return 0
      if grep -qxF absent "$_update_txn_dir/current.identity"; then
        if _kilix_entry_exists "$_fork_current"; then
          mv -- "$_fork_current" "$_update_txn_dir/failed-current.entry" || return 1
        fi
        return 0
      fi
      _kilix_write_entry_identity "$_fork_previous" "$_update_txn_dir/previous.after" || return 1
      cmp -s "$_update_txn_dir/current.identity" "$_update_txn_dir/previous.after" || return 1
      if _kilix_entry_exists "$_fork_current"; then
        mv -- "$_fork_current" "$_update_txn_dir/failed-current.entry" || return 1
      fi
      mv -- "$_fork_previous" "$_fork_current" || return 1
    }

    _kilix_restore_previous() {
      _kilix_write_entry_identity "$_fork_previous" "$_update_txn_dir/previous.live" || return 1
      if cmp -s "$_update_txn_dir/previous.identity" "$_update_txn_dir/previous.live"; then
        return 0
      fi
      if _kilix_entry_exists "$_fork_previous"; then
        mv -- "$_fork_previous" "$_update_txn_dir/failed-previous.entry" || return 1
      fi
      if grep -qxF absent "$_update_txn_dir/previous.identity"; then
        return 0
      fi
      _kilix_write_entry_identity "$_update_txn_dir/previous.entry" \
        "$_update_txn_dir/previous.parked" || return 1
      cmp -s "$_update_txn_dir/previous.identity" \
        "$_update_txn_dir/previous.parked" || return 1
      mv -- "$_update_txn_dir/previous.entry" "$_fork_previous" || return 1
    }

    _kilix_restore_fork_stamp() {
      local tmp
      if [ -f "$_update_txn_dir/fork-stamp.present" ]; then
        if _kilix_assert_safe_fork_stamp 2>/dev/null \
             && cmp -s "$_update_txn_dir/fork-stamp" "$_fork_stamp"; then
          return 0
        fi
      elif ! _kilix_entry_exists "$_fork_stamp"; then
        return 0
      fi
      if [ -d "$_fork_stamp" ] && [ ! -L "$_fork_stamp" ]; then
        return 1
      fi
      if [ ! -f "$_update_txn_dir/fork-stamp.present" ]; then
        rm -f -- "$_fork_stamp" || return 1
        return 0
      fi
      _kilix_ensure_private_directory "$KILIX_STATE_DIRECTORY" state || return 1
      tmp="$(mktemp "$KILIX_STATE_DIRECTORY/fork-built-ref.restore.XXXXXX")" || return 1
      if ! cp --preserve=mode,timestamps -- "$_update_txn_dir/fork-stamp" "$tmp" \
           || ! chmod 0600 "$tmp" \
           || ! mv -Tf -- "$tmp" "$_fork_stamp"; then
        rm -f -- "$tmp"
        return 1
      fi
      _kilix_assert_safe_fork_stamp || return 1
      cmp -s "$_update_txn_dir/fork-stamp" "$_fork_stamp" || return 1
    }

    _kilix_update_rollback() {
      local failed=0
      echo "kilix update: rolling changed state back to $_before" >&2
      _kilix_rollback_sources || failed=1
      if [ "$_engine_txn_active" = 1 ]; then
        _kilix_restore_current || failed=1
        _kilix_restore_previous || failed=1
        _kilix_restore_fork_stamp || failed=1
      fi
      return "$failed"
    }

    _kilix_cleanup_engine_transaction() {
      local entry cleanup_failed=0
      [ -n "$_update_txn_dir" ] || return 0
      for entry in "$_update_txn_dir/previous.entry" \
                   "$_update_txn_dir/failed-current.entry" \
                   "$_update_txn_dir/failed-previous.entry"; do
        _kilix_gc_generation_for_entry "$entry" || cleanup_failed=1
      done
      rm -rf -- "$_update_txn_dir" || cleanup_failed=1
      return "$cleanup_failed"
    }

    _kilix_update_cleanup() {
      local rc="$1" rollback_ok=1
      trap - EXIT INT TERM HUP
      set +e
      if [ "${_update_active:-0}" = 1 ] && [ "${_update_committed:-0}" != 1 ]; then
        [ "$rc" -ne 0 ] || rc=1
        _kilix_update_rollback || rollback_ok=0
      fi
      if [ "$rollback_ok" = 1 ]; then
        _kilix_cleanup_engine_transaction \
          || echo "kilix update: WARNING: rollback cleanup left safe recovery artifacts" >&2
      else
        echo "kilix update: automatic rollback was incomplete; recovery data retained at ${_update_txn_dir:-<none>}" >&2
        rc=70
      fi
      exit "$rc"
    }

    _kilix_commit_update_transaction() {
      _update_committed=1
      _update_active=0
      trap - EXIT INT TERM HUP
      set +e
      _kilix_cleanup_engine_transaction \
        || echo "kilix update: WARNING: update committed but old build cleanup was incomplete" >&2
      _update_txn_dir=""
      return 0
    }

    _kilix_assert_safe_fork_stamp || exit 1
    _before="$(git -C "$KILIX_HOME" rev-parse HEAD 2>/dev/null || echo unknown)"
    _before_branch="$(git -C "$KILIX_HOME" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"

    if [ -n "${KILIX_REF:-}" ]; then
      if ! [[ "$KILIX_REF" =~ ^[0-9a-fA-F]{40}$ ]] \
           && [ "${KILIX_ALLOW_MUTABLE_REF:-0}" != 1 ]; then
        echo "kilix update: KILIX_REF must be a full commit SHA" >&2
        echo "kilix update: set KILIX_ALLOW_MUTABLE_REF=1 only to trust a mutable tag/branch" >&2
        exit 1
      fi
      echo "kilix update: fetching ref $KILIX_REF from origin"
      git -C "$KILIX_HOME" fetch --tags --prune origin "$KILIX_REF" || exit $?
      _target="$(git -C "$KILIX_HOME" rev-parse --verify 'FETCH_HEAD^{commit}')" \
        || { echo "kilix update: $KILIX_REF did not resolve to a commit" >&2; exit 1; }
    else
      _branch="$(git -C "$KILIX_HOME" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
      if [ -z "$_branch" ]; then
        echo "kilix update: detached checkout requires KILIX_REF" >&2; exit 1
      fi
      _upstream="$(git -C "$KILIX_HOME" rev-parse --abbrev-ref '@{upstream}' 2>/dev/null || true)"
      if [ "$_upstream" != "origin/$_branch" ]; then
        echo "kilix update: branch $_branch must track origin/$_branch (found ${_upstream:-none})" >&2
        exit 1
      fi
      echo "kilix update: fetching origin/$_branch"
      git -C "$KILIX_HOME" fetch --prune origin "$_branch" || exit $?
    fi

    _update_active=1
    trap '_kilix_update_cleanup $?' EXIT
    trap 'exit 130' INT
    trap 'exit 143' TERM
    trap 'exit 129' HUP
    _update_sources_mutated=1
    if [ -n "${KILIX_REF:-}" ]; then
      git -C "$KILIX_HOME" checkout --detach "$_target" || exit $?
    else
      git -C "$KILIX_HOME" merge --ff-only "origin/$_branch" || exit $?
    fi
    if ! git -C "$KILIX_HOME" submodule update --init --recursive; then
      echo "kilix update: submodule update failed" >&2
      exit 1
    fi

    _fork_needs_rebuild=0
    if _kilix_has_fork_footprint && ! _kilix_fork_is_coherent; then
      _fork_needs_rebuild=1
    fi
    if [ "$_fork_needs_rebuild" = 1 ]; then
      if ! command -v go >/dev/null 2>&1; then
        echo "kilix update: Go not found; cannot rebuild the existing fork engine" >&2
        exit 1
      fi
      echo "kilix update: rebuilding existing fork engine ($_fork_invalid_reason)"
      _kilix_prepare_engine_transaction || exit 1
      if (cd "$KILIX_HOME" && "$KILIX_HOME/build.sh"); then
        :
      else
        _build_rc=$?
        echo "kilix update: fork rebuild failed (exit $_build_rc)" >&2
        exit 1
      fi
      if ! _kilix_fork_is_coherent; then
        echo "kilix update: rebuilt fork failed verification: $_fork_invalid_reason" >&2
        exit 1
      fi
    fi

    _engine_output="$(_kilix_which_output)" || {
      echo "kilix update: updated checkout has no runnable engine" >&2
      exit 1
    }
    _engine="${_engine_output%%$'\n'*}"
    [ -n "$_engine" ] || {
      echo "kilix update: updated checkout selected an empty engine path" >&2
      exit 1
    }
    _kilix_commit_update_transaction
    echo "kilix update: done — restart 'kilix desktop' to load the changes."
    exit 0 ;;
  --which)
    for b in "$FORK" "$PREBUILT"; do
      [ -x "$b" ] && { echo "$b"; exec "$b" --version; }
    done
    echo "no kitty built yet — run: $KILIX_HOME/kilix --build" >&2; exit 1 ;;
  --install-desktop)
    # Desktop entry + themed icon so kilix groups separately in the taskbar
    # (StartupWMClass matches the WM_CLASS set by --class below) and can be
    # pinned/launched from the app menu with its own icon.
    apps="${XDG_DATA_HOME:-$HOME/.local/share}/applications"
    icons="${XDG_DATA_HOME:-$HOME/.local/share}/icons/hicolor"
    for _i in kitty.app-128.png kitty.app.png kilix-512.png; do
      [ -f "$KILIX_HOME/config/$_i" ] || { echo "kilix: missing icon $KILIX_HOME/config/$_i" >&2; exit 1; }
    done
    mkdir -p "$apps" "$icons/128x128/apps" "$icons/256x256/apps" "$icons/512x512/apps"
    cp "$KILIX_HOME/config/kitty.app-128.png" "$icons/128x128/apps/kilix.png"
    cp "$KILIX_HOME/config/kitty.app.png"     "$icons/256x256/apps/kilix.png"
    cp "$KILIX_HOME/config/kilix-512.png"     "$icons/512x512/apps/kilix.png"
    cat > "$apps/kilix.desktop" <<EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=kilix
GenericName=Terminal Emulator
Comment=Tilix-styled kitty with clickable pane buttons
Exec="$KILIX_HOME/kilix"
Icon=kilix
Terminal=false
Categories=System;TerminalEmulator;
StartupWMClass=kilix
StartupNotify=true
EOF
    if command -v update-desktop-database >/dev/null; then
      update-desktop-database "$apps" || true
    fi
    if command -v gtk-update-icon-cache >/dev/null; then
      gtk-update-icon-cache -f -t "$icons" 2>/dev/null || true
    fi
    echo "installed: $apps/kilix.desktop (+ hicolor icons). Log out/in or restart your panel if the icon doesn't show immediately."
    exit 0 ;;
esac

if [ -x "$FORK" ]; then
  BIN="$FORK"                                     # prefer the clickable-chrome fork
elif [ -x "$PREBUILT" ]; then
  BIN="$PREBUILT"                                 # fall back to the prebuilt binary
elif [ "${1:-}" = "screen-size" ] || [ "${1:-}" = "font-size" ]; then
  BIN=""                                          # config-only command; no bootstrap side effect
else
  # nothing available yet: try building the fork, else pull the prebuilt binary
  if (cd "$KILIX_HOME" && "$KILIX_HOME/build.sh"); then BIN="$FORK"; else "$KILIX_HOME/bootstrap.sh"; BIN="$PREBUILT"; fi
fi
[ -z "${BIN:-}" ] || [ -x "$BIN" ] || { echo "kilix: no runnable kitty (build and bootstrap both failed)" >&2; exit 1; }

case "${1:-}" in
  # kitty subcommands (kitty +kitten icat …): + must be kitty's first arg,
  # so forward without --class.
  +*) exec "$BIN" "$@" ;;
esac

KITTEN="${KILIX_KITTEN:-}"
[ -n "${BIN:-}" ] && KITTEN="$(dirname "$BIN")/kitten"

_kilix_desktop_die() {
  echo "kilix desktop: $*" >&2
  exit 1
}

_kilix_remote_control() {
  [ -x "$KITTEN" ] || { echo "kilix $1: kitten not found next to $BIN" >&2; exit 1; }
  if [ -z "${KITTY_LISTEN_ON:-}" ]; then
    echo "kilix $1: no live kilix remote-control socket (run this inside kilix, or set KITTY_LISTEN_ON)" >&2
    exit 1
  fi
  KILIX_KITTEN="$KITTEN" exec python3 "$KILIX_HOME/config/remote.py" "$@"
}

_kilix_restore_pane_tty() {
  # pop kbd protocol; disable mouse (btn-event/SGR/pixels) + bracketed paste;
  # re-enable autowrap; delete all images; show cursor; leave alt screen. Each
  # code is a no-op if the pane app already restored it.
  printf '\033[<u\033[?1002l\033[?1003l\033[?1006l\033[?1016l\033[?2004l\033[?7h\033_Ga=d,d=A\033\\\033[?25h\033[?1049l'
  stty sane 2>/dev/null || true
}

_kilix_screen_size_usage() {
  cat >&2 <<EOF
usage: $_self screen-size [show|larger [STEP]|smaller [STEP]|reset|set POINTS|+POINTS|-POINTS|POINTS]

Adjusts Kilix's terminal scale by changing kitty's font_size. Larger text means
fewer terminal rows/columns fit on the same fullscreen display; smaller text
means more rows/columns fit.
EOF
}

_kilix_screen_size_config() {
  printf '%s\n' "${KITTY_CONFIG_DIRECTORY:-$KILIX_HOME/config}/kitty.conf"
}

_kilix_screen_size_current() {
  _conf="$(_kilix_screen_size_config)"
  if [ -f "$_conf" ]; then
    awk '$1 == "font_size" { v = $2 } END { if (v != "") print v; else print "11.0" }' "$_conf"
  else
    printf '11.0\n'
  fi
}

_kilix_screen_size_format() {
  awk -v v="$1" 'BEGIN {
    if (v < 4) v = 4;
    if (v > 110) v = 110;
    if (v == int(v)) printf "%d\n", v;
    else {
      s = sprintf("%.2f", v);
      sub(/0+$/, "", s);
      sub(/[.]$/, "", s);
      print s;
    }
  }'
}

_kilix_screen_size_calc() {
  awk -v cur="$1" -v delta="$2" 'BEGIN { printf "%.4f\n", cur + delta }' \
    | while IFS= read -r _v; do _kilix_screen_size_format "$_v"; done
}

_kilix_screen_size_valid() {
  awk -v v="$1" 'BEGIN { exit !(v ~ /^[0-9]+([.][0-9]+)?$/ && v + 0 >= 4 && v + 0 <= 110) }'
}

_kilix_screen_size_step_valid() {
  awk -v v="$1" 'BEGIN { exit !(v ~ /^[0-9]+([.][0-9]+)?$/) }'
}

_kilix_screen_size_write_config() {
  _size="$1"
  _conf="$(_kilix_screen_size_config)"
  _line="$(printf '%-30s %s' font_size "$_size")"
  mkdir -p "$(dirname "$_conf")"
  _tmp="$(mktemp)" || return 1
  if [ -f "$_conf" ]; then
    awk -v line="$_line" '
      { lines[NR] = $0 }
      $1 == "font_size" { last = NR }
      END {
        if (NR == 0) {
          print "# -- kilix screen-size --";
          print line;
          exit;
        }
        for (i = 1; i <= NR; i++) {
          if (i == last) print line;
          else print lines[i];
        }
        if (!last) {
          print "";
          print "# -- kilix screen-size --";
          print line;
        }
      }' "$_conf" >"$_tmp"
  else
    printf '%s\n%s\n' "# -- kilix screen-size --" "$_line" >"$_tmp"
  fi
  mv "$_tmp" "$_conf"
}

_kilix_screen_size_apply_live() {
  _size="$1"
  if [ -n "${KITTY_LISTEN_ON:-}" ] && [ -x "$KITTEN" ]; then
    "$KITTEN" @ action load_config_file >/dev/null 2>&1 || true
    "$KITTEN" @ set-font-size --all "$_size" >/dev/null 2>&1 || true
  elif [ -n "${KITTY_PID:-}" ] && [[ "$KITTY_PID" =~ ^[0-9]+$ ]]; then
    kill -USR1 "$KITTY_PID" 2>/dev/null || true
  fi
}

_kilix_screen_size_cmd() {
  _action="${1:-show}"
  [ $# -gt 0 ] && shift
  _cur="$(_kilix_screen_size_current)"
  case "$_action" in
    show|status|get)
      printf 'font_size %s\n' "$_cur"
      return 0 ;;
    larger|increase|up|plus)
      _step="${1:-2}"
      [ $# -le 1 ] || { _kilix_screen_size_usage; return 2; }
      _kilix_screen_size_step_valid "$_step" || { _kilix_screen_size_usage; return 2; }
      _new="$(_kilix_screen_size_calc "$_cur" "$_step")" ;;
    smaller|decrease|down|minus)
      _step="${1:-2}"
      [ $# -le 1 ] || { _kilix_screen_size_usage; return 2; }
      _kilix_screen_size_step_valid "$_step" || { _kilix_screen_size_usage; return 2; }
      _new="$(_kilix_screen_size_calc "$_cur" "-$_step")" ;;
    reset|default)
      [ $# -eq 0 ] || { _kilix_screen_size_usage; return 2; }
      _new="11.0" ;;
    set)
      [ $# -eq 1 ] || { _kilix_screen_size_usage; return 2; }
      _kilix_screen_size_valid "$1" || { _kilix_screen_size_usage; return 2; }
      _new="$1" ;;
    +*)
      [ $# -eq 0 ] || { _kilix_screen_size_usage; return 2; }
      _step="${_action#+}"
      _kilix_screen_size_step_valid "$_step" || { _kilix_screen_size_usage; return 2; }
      _new="$(_kilix_screen_size_calc "$_cur" "$_step")" ;;
    -h|--help|help)
      _kilix_screen_size_usage
      return 0 ;;
    -*)
      [ $# -eq 0 ] || { _kilix_screen_size_usage; return 2; }
      _step="${_action#-}"
      _kilix_screen_size_step_valid "$_step" || { _kilix_screen_size_usage; return 2; }
      _new="$(_kilix_screen_size_calc "$_cur" "-$_step")" ;;
    [0-9]*)
      [ $# -eq 0 ] || { _kilix_screen_size_usage; return 2; }
      _kilix_screen_size_valid "$_action" || { _kilix_screen_size_usage; return 2; }
      _new="$_action" ;;
    *)
      _kilix_screen_size_usage
      return 2 ;;
  esac
  _new="$(_kilix_screen_size_format "$_new")"
  if ! _kilix_screen_size_valid "$_new"; then
    echo "kilix screen-size: font size must be between 4 and 110 points" >&2
    return 2
  fi
  _kilix_screen_size_write_config "$_new"
  _kilix_screen_size_apply_live "$_new"
  printf 'font_size %s\n' "$_new"
}

case "${1:-}" in
  ls|focus|watch|fullscreen)
    _remote_cmd="$1"; shift
    _kilix_remote_control "$_remote_cmd" "$@" ;;
  screen-size|font-size)
    _remote_cmd="$1"; shift
    _kilix_screen_size_cmd "$@"
    exit $? ;;
esac

_kilix95_checkout_ref() {
  [ -n "${KILIX95_REF:-}" ] || return 0
  if ! [[ "$KILIX95_REF" =~ ^[0-9a-fA-F]{40}$ ]]; then
    [ "${KILIX95_ALLOW_MUTABLE_REF:-0}" = 1 ] \
      || _kilix_desktop_die "KILIX95_REF must be a full 40-character commit SHA (set KILIX95_ALLOW_MUTABLE_REF=1 to trust a mutable tag/branch)"
  fi
  if [ -n "$(git -C "$_k95_dir" status --porcelain --untracked-files=normal 2>/dev/null)" ]; then
    _kilix_desktop_die "ref checkout refused because $_k95_dir has local modifications"
  fi
  git -C "$_k95_dir" fetch --force origin "$KILIX95_REF" \
    || _kilix_desktop_die "could not fetch KILIX95_REF=$KILIX95_REF"
  _k95_target="$(git -C "$_k95_dir" rev-parse --verify 'FETCH_HEAD^{commit}')" \
    || _kilix_desktop_die "KILIX95_REF did not resolve to a commit"
  git -C "$_k95_dir" checkout --detach "$_k95_target" \
    || _kilix_desktop_die "could not check out KILIX95_REF=$KILIX95_REF"
}

_kilix_desktop_validate() {
  python3 "$KILIX_HOME/scripts/check-desktop-provider.py" "$1" \
    || _kilix_desktop_die "provider contract validation failed for $1"
}

_kilix95_ensure_external() {
  _k95_dir="$KILIX95_DIR"
  _k95_repo="${KILIX95_REPO:-https://github.com/itsmygithubacct/kilix-95.git}"

  if [ -f "$_k95_dir/main.py" ]; then
    if [ -d "$_k95_dir/.git" ]; then
      _k95_origin="$(git -C "$_k95_dir" config --get remote.origin.url 2>/dev/null || true)"
      if [ "$_k95_origin" != "$_k95_repo" ] \
           && [ "${KILIX95_TRUST_EXISTING_CHECKOUT:-0}" != 1 ]; then
        _kilix_desktop_die "$_k95_dir has origin '${_k95_origin:-missing}', expected '$_k95_repo' (set KILIX95_TRUST_EXISTING_CHECKOUT=1 to override)"
      fi
      _kilix95_checkout_ref
    elif [ "${KILIX95_TRUST_EXISTING_CHECKOUT:-0}" != 1 ]; then
      _kilix_desktop_die "$_k95_dir is not a git checkout (set KILIX95_TRUST_EXISTING_CHECKOUT=1 only for trusted packaged providers)"
    fi
    if [ -z "${KILIX95_REF:-}" ]; then
      echo "kilix desktop: WARNING: external provider is not pinned; set KILIX95_REF to its full commit SHA for reproducible launches" >&2
    fi
    _kilix_desktop_validate "$_k95_dir"
    _KILIX_DESKTOP_MAIN="$_k95_dir/main.py"
    _KILIX_DESKTOP_MODE=python
    return 0
  fi
  if [ "${KILIX95_AUTO_INSTALL:-0}" != 1 ]; then
    _kilix_desktop_die "Kilix 95 is not installed at $_k95_dir; set KILIX95_AUTO_INSTALL=1 to clone $_k95_repo"
  fi
  if [ -e "$_k95_dir" ] && [ ! -d "$_k95_dir/.git" ]; then
    _kilix_desktop_die "$_k95_dir exists but is not a Kilix 95 checkout"
  fi
  command -v git >/dev/null 2>&1 || _kilix_desktop_die "git is required to clone Kilix 95"
  if [ -z "${KILIX95_REF:-}" ] \
       && [ "${KILIX95_ALLOW_UNPINNED_INSTALL:-0}" != 1 ]; then
    _kilix_desktop_die "automatic provider install requires an immutable KILIX95_REF commit SHA (or explicit KILIX95_ALLOW_UNPINNED_INSTALL=1)"
  fi

  echo "kilix desktop: cloning Kilix 95 -> $_k95_dir" >&2
  _clone_args=()
  [ -n "${KILIX95_BRANCH:-}" ] && _clone_args=(--branch "$KILIX95_BRANCH")
  mkdir -p "$(dirname "$_k95_dir")"
  git clone "${_clone_args[@]}" "$_k95_repo" "$_k95_dir" \
    || _kilix_desktop_die "git clone failed ($_k95_repo)"
  _kilix95_checkout_ref
  [ -f "$_k95_dir/main.py" ] || _kilix_desktop_die "missing main.py in $_k95_dir"
  if [ -z "${KILIX95_REF:-}" ]; then
    echo "kilix desktop: WARNING: installed provider is unpinned by explicit override" >&2
  fi
  _kilix_desktop_validate "$_k95_dir"
  _KILIX_DESKTOP_MAIN="$_k95_dir/main.py"
  _KILIX_DESKTOP_MODE=python
}

_kilix_desktop_select() {
  _KILIX_DESKTOP_MAIN=
  _KILIX_DESKTOP_MODE=
  _k95_provider="${KILIX_DESKTOP_PROVIDER:-auto}"
  _k95_builtin="$KILIX_HOME/desktop/main.py"

  case "$_k95_provider" in
    none|off|disabled)
      _KILIX_DESKTOP_MODE=none ;;
    command|custom)
      [ -n "${KILIX_DESKTOP_COMMAND:-}" ] \
        || _kilix_desktop_die "KILIX_DESKTOP_PROVIDER=$_k95_provider requires KILIX_DESKTOP_COMMAND"
      _KILIX_DESKTOP_MODE="command" ;;
    builtin)
      [ -f "$_k95_builtin" ] || _kilix_desktop_die "built-in desktop is not present at $_k95_builtin"
      _kilix_desktop_validate "$KILIX_HOME/desktop"
      _KILIX_DESKTOP_MAIN="$_k95_builtin"
      _KILIX_DESKTOP_MODE=python ;;
    external)
      _kilix95_ensure_external ;;
    auto)
      _auto_external="$KILIX95_DIR"
      if [ -f "$_auto_external/main.py" ]; then
        _kilix95_ensure_external
      elif [ -f "$_k95_builtin" ]; then
        echo "kilix desktop: external authoritative provider not found; using the bundled compatibility fallback" >&2
        _kilix_desktop_validate "$KILIX_HOME/desktop"
        _KILIX_DESKTOP_MAIN="$_k95_builtin"
        _KILIX_DESKTOP_MODE=python
      else
        _kilix95_ensure_external
      fi ;;
    *)
      _kilix_desktop_die "unknown KILIX_DESKTOP_PROVIDER=$_k95_provider (use auto, builtin, external, command, or none)" ;;
  esac
}

# browse: Chrome (and video) rendered in a pane. Host it in its own overlay
# WINDOW so it gets a title bar with a clickable close button — closing the
# overlay exits the app and reveals the shell underneath, which is never
# taken over. Needs to be inside a kitty window with remote control
# (KITTY_LISTEN_ON, set by the allow_remote_control + listen_on config).
# KILIX_IN_OVERLAY guards against the re-launched instance overlaying again.
if [ "${1:-}" = "browse" ]; then
  shift
  if [ -z "${KILIX_IN_OVERLAY:-}" ] && [ -n "${KITTY_WINDOW_ID:-}" ] \
       && [ -n "${KITTY_LISTEN_ON:-}" ] && [ -x "$KITTEN" ]; then
    # Spawn the app as an overlay over the current window; the launcher then
    # exits and the shell returns to its prompt (hidden under the overlay
    # until it is closed). The overlay re-enters this launcher with
    # KILIX_IN_OVERLAY=1, taking the in-place branch below.
    exec "$KITTEN" @ --password-file "$KILIX_RC_PASSWORD_FILE" \
      launch --type=overlay --cwd=current --self \
      --env KILIX_IN_OVERLAY=1 --env "KILIX_STREAM=${KILIX_STREAM:-}" \
      --env "KILIX_BROWSE_BACKEND=${KILIX_BROWSE_BACKEND:-presenter}" \
      -- "$_self" browse "$@"
  fi
  # In-place fallback: inside the overlay, or a terminal without remote
  # control. Run WRAPPED, not exec'd: if the app dies by signal (SIGKILL,
  # etc.) without running its own terminal cleanup, restore the tty here so
  # the shell stays usable. A clean exit (rc < 128) already cleaned up.
  rc=0
  _browse_backend=${KILIX_BROWSE_BACKEND:-presenter}
  case "$_browse_backend" in
    presenter|python)
      # Keep one Kitty image stable and update it through the shared
      # FramePresenter.  The legacy Go kitten retransmits a=T for every CDP
      # frame, which can expose the terminal background for one refresh while
      # scrolling under a virtual GPU.
      python3 "$KILIX_HOME/config/browse.py" "$@" || rc=$? ;;
    go)
      if [ -x "$KITTEN" ] && "$KITTEN" --help 2>/dev/null \
           | sed -n '/^Commands:/,/^$/p' | grep -qFx "   browse"; then
        "$KITTEN" browse "$@" || rc=$?
      else
        echo "kilix browse: KILIX_BROWSE_BACKEND=go requires the built-in browse kitten" >&2
        rc=1
      fi ;;
    *)
      echo "kilix browse: unknown KILIX_BROWSE_BACKEND=$_browse_backend (use presenter or go)" >&2
      rc=2 ;;
  esac
  [ "$rc" -eq 0 ] || _kilix_restore_pane_tty
  exit "$rc"
fi

# run: an X11 app streamed into a pane (private Xvfb + x11grab + XTest).
# Python prototype only for now. Same wrapped-cleanup story as browse above,
# but the default target is a new TAB, not an overlay: the launching shell
# stays visible in its own tab and closing the app's tab exits the app. If
# the kitten dies by signal, restore the tty by hand.
if [ "${1:-}" = "run" ]; then
  shift
  if [ -z "${KILIX_IN_OVERLAY:-}" ] && [ -n "${KITTY_WINDOW_ID:-}" ] \
       && [ -n "${KITTY_LISTEN_ON:-}" ] && [ -x "$KITTEN" ]; then
    # Tab title: the first non-flag arg is the app command (--size/--fps
    # take a separate value in their unglued form, so skip it).
    _app=run; _skip=
    for _a in "$@"; do
      if [ -n "$_skip" ]; then _skip=; continue; fi
      case "$_a" in
        --size|--fps) _skip=1 ;;
        --*) ;;
        *) _app=${_a##*/}; break ;;
      esac
    done
    # KILIX_IN_OVERLAY doubles as the generic "already relaunched into our
    # own kitty window" guard, whatever the window type.
    exec "$KITTEN" @ --password-file "$KILIX_RC_PASSWORD_FILE" \
      launch --type=tab --cwd=current --self --tab-title "$_app" \
      --env KILIX_IN_OVERLAY=1 --env "KILIX_STREAM=${KILIX_STREAM:-}" \
      -- "$_self" run "$@"
  fi
  rc=0
  python3 "$KILIX_HOME/config/apprun.py" "$@" || rc=$?
  [ "$rc" -eq 0 ] || _kilix_restore_pane_tty
  exit "$rc"
fi

# desktop: a Windows 95-style desktop environment rendered as pixels in a
# kilix tab (start bar, launchers, file manager, Notepad, Settings that edits
# the kilix config live). Modules live in ./desktop/. Same host-in-own-tab +
# wrapped-cleanup story as run; quit via Start > Shut Down (or Ctrl+Alt+Q).
if [ "${1:-}" = "desktop" ]; then
  shift
  _kilix_desktop_select
  if [ "$_KILIX_DESKTOP_MODE" = python ] \
       && [ "$_KILIX_DESKTOP_MAIN" != "$KILIX_HOME/desktop/main.py" ]; then
    if [ -z "${KILIX_STATE_LIBRARY:-}" ]; then
      "$KILIX_HOME/scripts/build-state-library.sh" \
        || _kilix_desktop_die "could not prepare the pinned state library"
      KILIX_STATE_LIBRARY="$KILIX_BUILD_DIRECTORY/libraries/kilix-state/libkilix-state.so"
    fi
    export KILIX_STATE_LIBRARY
  fi
  if [ -z "${KILIX_IN_OVERLAY:-}" ] && [ -n "${KITTY_WINDOW_ID:-}" ] \
       && [ -n "${KITTY_LISTEN_ON:-}" ] && [ -x "$KITTEN" ]; then
    # Only one kilix 95 desktop at a time: if one is already running in this
    # kitty, switch to it instead of opening a second — two desktops fight over
    # the graphics transport. Find the window whose foreground process is the
    # desktop (kitty's cmdline: match sees only the launch command, not the
    # python child, so ask @ ls and check foreground_processes) and focus it.
    _dwid=""
    if [ "$_KILIX_DESKTOP_MODE" = python ]; then
      _dwid="$(KILIX_DESKTOP_MAIN="$_KILIX_DESKTOP_MAIN" "$KITTEN" @ --password-file "$KILIX_RC_PASSWORD_FILE" ls 2>/dev/null | python3 -c 'import json,os,sys
try: d=json.load(sys.stdin)
except Exception: sys.exit(0)
targets={os.environ.get("KILIX_DESKTOP_MAIN","")}
targets={t for t in targets if t}
def is_desktop_arg(a):
    return a in targets or a.endswith("/desktop/main.py") or a.endswith("/kilix-95/main.py")
ids=[w["id"] for o in d for t in o.get("tabs",[]) for w in t.get("windows",[]) if any(is_desktop_arg(a) for p in w.get("foreground_processes",[]) for a in p.get("cmdline",[]))]
print(ids[0] if ids else "")' 2>/dev/null)"
    fi
    if [ -n "$_dwid" ]; then
      "$KITTEN" @ --password-file "$KILIX_RC_PASSWORD_FILE" focus-window --match "id:$_dwid" >/dev/null 2>&1
      exit 0
    fi
    exec "$KITTEN" @ --password-file "$KILIX_RC_PASSWORD_FILE" \
      launch --type=tab --cwd=current --self --tab-title "${KILIX_DESKTOP_NAME:-desktop}" \
      --env KILIX_IN_OVERLAY=1 --env "KILIX_STREAM=${KILIX_STREAM:-}" \
      --env "GPU_TERMINAL_SOURCE_HOME=$GPU_TERMINAL_SOURCE_HOME" \
      --env "GPU_TERMINAL_HOME=$GPU_TERMINAL_HOME" \
      --env "KILIX_STORAGE_HOME=$KILIX_STORAGE_HOME" \
      --env "KILIX_CONFIG_HOME=$KILIX_CONFIG_HOME" \
      --env "KILIX_STATE_DIRECTORY=$KILIX_STATE_DIRECTORY" \
      --env "KILIX_CACHE_HOME=$KILIX_CACHE_HOME" \
      --env "KILIX_SESSION_HOME=$KILIX_SESSION_HOME" \
      --env "KILIX_DATA_HOME=$KILIX_DATA_HOME" \
      --env "KILIX_BUILD_DIRECTORY=$KILIX_BUILD_DIRECTORY" \
      --env "KILIX_PREBUILT_HOME=$KILIX_PREBUILT_HOME" \
      --env "KILIX_STATE_LIBRARY=${KILIX_STATE_LIBRARY:-}" \
      --env "KILIX_DESKTOP_PROVIDER=${KILIX_DESKTOP_PROVIDER:-}" \
      --env "KILIX_DESKTOP_COMMAND=${KILIX_DESKTOP_COMMAND:-}" \
      --env "KILIX_DESKTOP_NAME=${KILIX_DESKTOP_NAME:-}" \
      --env "KILIX_DESKTOP_FLAVOR=${KILIX_DESKTOP_FLAVOR:-}" \
      --env "KILIX95_AUTO_INSTALL=${KILIX95_AUTO_INSTALL:-}" \
      --env "KILIX95_DIR=$KILIX95_DIR" \
      --env "KILIX95_REPO=${KILIX95_REPO:-}" \
      --env "KILIX95_BRANCH=${KILIX95_BRANCH:-}" \
      --env "KILIX95_REF=${KILIX95_REF:-}" \
      --env "KILIX95_STORAGE_HOME=$KILIX95_STORAGE_HOME" \
      --env "KILIX95_CONFIG_HOME=$KILIX95_CONFIG_HOME" \
      --env "KILIX95_STATE_HOME=$KILIX95_STATE_HOME" \
      --env "KILIX95_CACHE_HOME=$KILIX95_CACHE_HOME" \
      --env "KILIX95_SESSION_HOME=$KILIX95_SESSION_HOME" \
      --env "KILIX95_DATA_HOME=$KILIX95_DATA_HOME" \
      -- "$_self" desktop "$@"
  fi
  rc=0
  case "$_KILIX_DESKTOP_MODE" in
    none)
      echo "kilix desktop: disabled by KILIX_DESKTOP_PROVIDER=$_k95_provider" >&2
      exit 0 ;;
    command)
      KILIX_HOME="$KILIX_HOME" KILIX_KITTEN="$KITTEN" \
        sh -c "$KILIX_DESKTOP_COMMAND" "${KILIX_DESKTOP_NAME:-desktop}" "$@" || rc=$? ;;
    python)
      if [ "$_KILIX_DESKTOP_MAIN" = "$KILIX_HOME/desktop/main.py" ]; then
        _desktop_pycache="$KILIX_CACHE_HOME/desktop-pycache"
      else
        _desktop_pycache="${KILIX95_CACHE_HOME:-$KILIX95_STORAGE_HOME/cache}/pycache"
      fi
      mkdir -p "$_desktop_pycache"
      KILIX_HOME="$KILIX_HOME" KILIX95_HOME="$(dirname "$_KILIX_DESKTOP_MAIN")" \
        KILIX_KITTEN="$KITTEN" PYTHONPYCACHEPREFIX="$_desktop_pycache" \
        python3 "$_KILIX_DESKTOP_MAIN" "$@" || rc=$? ;;
    *)
      _kilix_desktop_die "internal error: no desktop mode selected" ;;
  esac
  [ "$rc" -eq 0 ] || _kilix_restore_pane_tty
  exit "$rc"
fi

# share: run the WHOLE kilix on a headless display and stream it to multiple
# devices (Phase 3). Pixels go out as HLS (any browser/player, many viewers);
# a remote viewer's keyboard/mouse are injected with XTest. Runs in the current
# pane, printing connect instructions; Ctrl+C stops it. Loopback by default;
# `--lan` serves the LAN over TLS + token. `--size WxH` sets the virtual screen.
# (This was `kilix desktop` before the desktop environment claimed that name.)
if [ "${1:-}" = "share" ]; then
  shift
  KILIX_KITTY="$BIN" exec python3 "$KILIX_HOME/config/share.py" "$@"
fi

# mux: open a kilix tab that is backed by the private tmux server from the
# start. Unlike `kilix watch`, this is real terminal multiplexing: attach/view
# can reconnect to it later because the shell is born inside tmux.
if [ "${1:-}" = "mux" ]; then
  shift
  case "${1:-}" in
    -h|--help)
      echo "usage: $_self mux [a|attach] [session-name]" >&2
      exit 0 ;;
    a|attach)
      shift ;;
  esac
  [ $# -le 1 ] || { echo "usage: $_self mux [a|attach] [session-name]" >&2; exit 2; }
  _mux_name="${1:-main}"
  if [ -z "${KILIX_IN_OVERLAY:-}" ] && [ -n "${KITTY_WINDOW_ID:-}" ] \
       && [ -n "${KITTY_LISTEN_ON:-}" ] && [ -x "$KITTEN" ]; then
    exec "$KITTEN" @ --password-file "$KILIX_RC_PASSWORD_FILE" \
      launch --type=tab --cwd=current --self --tab-title "mux:$_mux_name" \
      --env KILIX_IN_OVERLAY=1 --env KILIX_STREAM=1 -- "$_self" serve "$_mux_name"
  fi
  exec "$_self" serve "$_mux_name"
fi

# screensaver: a terminal screensaver in this pane (default: matrix). The
# screensavers are small self-contained C programs in config/screensavers/,
# compiled on first use and cached under the Kilix cache root (needs a C
# compiler, like the fork build). Usage: `kilix screensaver` or
# `kilix screensaver <name>`.
if [ "${1:-}" = "screensaver" ]; then
  shift
  # Host it in an overlay window (own title bar + close ✕) like browse/run, so
  # it can be dismissed with a click and reveals the shell underneath.
  if [ -z "${KILIX_IN_OVERLAY:-}" ] && [ -n "${KITTY_WINDOW_ID:-}" ] \
       && [ -n "${KITTY_LISTEN_ON:-}" ] && [ -x "$KITTEN" ]; then
    exec "$KITTEN" @ --password-file "$KILIX_RC_PASSWORD_FILE" \
      launch --type=overlay --cwd=current --self \
      --env KILIX_IN_OVERLAY=1 -- "$_self" screensaver "$@"
  fi
  _ss="${1:-matrix}"; [ $# -gt 0 ] && shift
  _sssrc="$KILIX_HOME/config/screensavers/$_ss.c"
  _sscache="$KILIX_CACHE_HOME/screensavers"
  _ssbin="$_sscache/$_ss"
  if [ ! -f "$_sssrc" ]; then
    echo "kilix: no screensaver '$_ss'. Available:" >&2
    for _f in "$KILIX_HOME"/config/screensavers/*.c; do
      [ -e "$_f" ] && echo "  $(basename "$_f" .c)" >&2
    done
    exit 1
  fi
  if [ ! -x "$_ssbin" ] || [ "$_sssrc" -nt "$_ssbin" ]; then     # (re)build if stale
    mkdir -p "$_sscache"
    cc -O2 -o "$_ssbin" "$_sssrc" || {
      echo "kilix: could not build screensaver '$_ss' (needs a C compiler)" >&2; exit 1; }
  fi
  exec "$_ssbin" "$@"
fi

# serve / attach / view — session persistence + multi-device attach (Phase 1
# "text plane"). A PRIVATE tmux server on a socket under the kilix runtime dir
# (never your ~/.tmux.conf) keeps a kilix session alive across disconnects and
# lets several devices attach at once: read-write (attach) or read-only (view).
# KILIX_STREAM=1 is set in the session so `kilix browse/run/icat` use inline
# (t=d) graphics that survive a remote attach. Reach it from another device over
# SSH, e.g.  ssh -t user@host ~/gpu_terminal/kilix/kilix attach
case "${1:-}" in
  serve|attach|view)
    command -v tmux >/dev/null 2>&1 || {
      echo "kilix $1: needs tmux (session multiplexing) — not found" >&2; exit 1; }
    _rundir="$KILIX_SESSION_HOME/tmux"
    if mkdir -p "$_rundir"; then chmod 700 "$_rundir" 2>/dev/null || true; fi
    _sock="$_rundir/tmux.sock"
    _tconf="$KILIX_HOME/config/tmux.conf"
    _sub="$1"; shift
    case "${1:-}" in
      ls|list|status)
        tmux -S "$_sock" list-sessions 2>/dev/null || echo "kilix: no sessions running"
        exit 0 ;;
      kill|clean)
        shift
        if [ -n "${1:-}" ]; then exec tmux -S "$_sock" kill-session -t "kilix-$1"; fi
        # no name: stop everything — text sessions AND any pixel-plane strays
        # (Xvnc/Xvfb/ffmpeg/bridge) left by a SIGKILLed serve.
        python3 -c "import sys;sys.path.insert(0,'$KILIX_HOME/config');import stream;print('kilix: reaped',stream.kill_all(),'stream processes')" 2>/dev/null || true
        if tmux -S "$_sock" kill-server 2>/dev/null; then
          echo "kilix: stopped tmux sessions"
        fi
        exit 0 ;;
    esac
    _name="${1:-main}"; _session="kilix-$_name"
    case "$_sub" in
      serve)
        _ushell="${SHELL:-$(getent passwd "$(id -un)" 2>/dev/null | cut -d: -f7)}"
        _ushell="${_ushell:-/bin/bash}"
        if [ -f "$KILIX_HOME/config/kilix.bashrc" ] && [ "${_ushell##*/}" = bash ]; then
          _shcmd="$_ushell --rcfile $KILIX_HOME/config/kilix.bashrc"
        else
          _shcmd="$_ushell"
        fi
        echo "kilix serve: session '$_session' (socket $_sock)"
        echo "  attach (read-write):  $_self attach $_name"
        echo "  view   (read-only) :  $_self view $_name"
        echo "  another device     :  ssh -t $(id -un)@$(hostname 2>/dev/null || echo HOST) $_self attach $_name"
        exec tmux -S "$_sock" -f "$_tconf" new-session -A -s "$_session" \
          -e KILIX_STREAM=1 -e "KILIX_HOME=$KILIX_HOME" \
          -e "KITTY_CONFIG_DIRECTORY=$KITTY_CONFIG_DIRECTORY" "$_shcmd" ;;
      attach) exec tmux -S "$_sock" attach-session -t "$_session" ;;
      view)   exec tmux -S "$_sock" attach-session -r -t "$_session" ;;
    esac ;;
esac

# icat inside a streamed session: force inline (stream) transmission + unicode
# placeholders so images survive a remote/tmux attach; locally, plain icat.
if [ "${1:-}" = icat ] && [ -x "$KITTEN" ]; then
  shift
  if [ "${KILIX_STREAM:-}" = 1 ]; then
    exec "$KITTEN" icat --transfer-mode=stream --unicode-placeholder "$@"
  fi
  exec "$KITTEN" icat "$@"
fi

# Kittens (kilix icat foo.png, kilix diff a b, …) run via the sibling kitten
# launcher, not by opening a new terminal window. The kitten list is probed
# from `kitten --help` so it tracks whatever the active binary ships; any
# non-kitten bare word still falls through to kitty (= run it in a window).
if [ $# -gt 0 ] && [ -x "$KITTEN" ]; then
  case "$1" in
    -*) ;;  # an option, not a kitten name
    *)
      if "$KITTEN" --help 2>/dev/null | sed -n '/^Commands:/,/^$/p' | grep -qFx "   $1"; then
        exec "$KITTEN" "$@"
      fi ;;
  esac
fi

# Carry prompt/shell tweaks in config/kilix.bashrc instead of ~/.bashrc, so
# they apply only to kilix sessions — not regular shells or tmux. bash only
# (the rcfile is bash); it sources ~/.bashrc, keeps kitty's shell integration
# working, then applies a kilix-only prompt. Delete config/kilix.bashrc to opt
# out. KILIX_HOME is exported so the rcfile can find its prompt override.
export KILIX_HOME
KILIX_SHELL=()
_ushell="${SHELL:-$(getent passwd "$(id -un)" 2>/dev/null | cut -d: -f7)}"
if [ "${KILIX_SHELL_INTEGRATION:-1}" != 0 ] \
     && [ -f "$KILIX_HOME/config/kilix.bashrc" ] && [ "${_ushell##*/}" = bash ]; then
  KILIX_SHELL=(-o "shell=$_ushell --rcfile $KILIX_HOME/config/kilix.bashrc")
fi

# --class kilix: own WM_CLASS/app_id so kilix groups separately from kitty
# in the taskbar and picks up the kilix icon via kilix.desktop.
exec "$BIN" --class kilix \
  --config "$KITTY_CONFIG_DIRECTORY/kitty.conf" \
  --config "$KILIX_RC_CONFIG_FILE" \
  "${KILIX_SHELL[@]}" "$@"
